/* 莫兰迪暖色系设计令牌 - GachaPlanner 全局样式 */
/* v2.0: 引入语义化 Token + 深色模式支持 */

/* 导入样式模块 */
@import './styles/theme.wxss';
@import './styles/common.wxss';

/* ============================================================
   Light 模式变量（默认值）
   作用于：page 节点 + 强制浅色的 view 节点
   ============================================================ */
page,
.force-light {
  /* ---------- 主色系 ---------- */
  --color-primary: #C4A77D;
  --color-primary-light: #D4BC99;
  --color-primary-dark: #A68B5B;

  /* ---------- 辅助色系 ---------- */
  --color-secondary: #D4A5A5;

  /* ---------- 功能色系 ---------- */
  --color-success: #7FB069;
  --color-warning: #C4A050;
  --color-danger: #C47070;
  --color-info: #6B8BA4;

  /* ---------- 中性色（暖灰色） ---------- */
  --color-gray-50: #FAF9F7;
  --color-gray-100: #F5F3F0;
  --color-gray-200: #E8E4DE;
  --color-gray-300: #D4CFC6;
  --color-gray-400: #B8B0A3;
  --color-gray-500: #9C9285;
  --color-gray-600: #7A7168;
  --color-gray-700: #5C544D;
  --color-gray-800: #3E3833;
  --color-gray-900: #1F1B18;

  /* ---------- 间距系统 ---------- */
  --spacing-xs: 4px;
  --spacing-sm: 8px;
  --spacing-md: 12px;
  --spacing-lg: 16px;
  --spacing-xl: 24px;
  --spacing-2xl: 32px;
  --spacing-3xl: 48px;

  /* ---------- 圆角系统 ---------- */
  --radius-sm: 4px;
  --radius-md: 8px;
  --radius-lg: 12px;
  --radius-xl: 16px;
  --radius-full: 9999px;

  /* ---------- 字体系统 ---------- */
  --font-size-xs: 12px;
  --font-size-sm: 14px;
  --font-size-base: 16px;
  --font-size-lg: 18px;
  --font-size-xl: 20px;
  --font-size-2xl: 24px;
  --font-size-3xl: 32px;

  /* ---------- 字重系统 ---------- */
  --font-weight-normal: 400;
  --font-weight-medium: 500;
  --font-weight-semibold: 600;
  --font-weight-bold: 700;

  /* ---------- 行高系统 ---------- */
  --line-height-tight: 1.25;
  --line-height-normal: 1.5;
  --line-height-relaxed: 1.75;

  /* ---------- 阴影系统 ---------- */
  --shadow-sm: 0 1px 2px 0 var(--color-shadow);
  --shadow-md: 0 4px 6px -1px var(--color-shadow);
  --shadow-lg: 0 10px 15px -3px var(--color-shadow);
  --shadow-xl: 0 20px 25px -5px var(--color-shadow);

  /* ---------- 动画时长 ---------- */
  --duration-fast: 150ms;
  --duration-normal: 300ms;
  --duration-slow: 500ms;

  /* ---------- 层级系统 ---------- */
  --z-index-dropdown: 1000;
  --z-index-sticky: 1020;
  --z-index-fixed: 1030;
  --z-index-modal-backdrop: 1040;
  --z-index-modal: 1050;
  --z-index-popover: 1060;
  --z-index-tooltip: 1070;

  /* ---------- 语义化 Token - Light ---------- */
  --color-bg-page: #FAF9F7;
  --color-bg-card: #FFFFFF;
  --color-bg-card-elevated: #FFFFFF;
  --color-bg-popover: #FFFFFF;
  --color-bg-toast: #2C2520;
  --color-bg-input: #FFFFFF;
  --color-bg-button: var(--color-primary);
  --color-bg-overlay: rgba(31, 27, 24, 0.5);

  --color-text-primary: #1F1B18;
  --color-text-secondary: #7A7168;
  --color-text-muted: #6B6358;
  --color-text-inverse: #FFFFFF;
  --color-text-link: var(--color-primary);

  --color-border-default: #E8E4DE;
  --color-border-divider: #E8E4DE;
  --color-border-focus: var(--color-primary);

  --color-shadow: rgba(0, 0, 0, 0.08);
  --color-shadow-ambient: rgba(0, 0, 0, 0.04);

  --color-state-success-bg: #F0F7EC;
  --color-state-success-text: #5A8F4A;
  --color-state-warning-bg: #F5EDD8;
  --color-state-warning-text: #8B6B30;
  --color-state-error-bg: #FDE8E8;
  --color-state-error-text: #B05050;

  /* ---------- 旧变量兼容别名 ---------- */
  --primary: var(--color-primary);
  --primary-light: var(--color-primary-light);
  --primary-dark: var(--color-primary-dark);
  --secondary: var(--color-secondary);
  --success: var(--color-success);
  --success-light: #9FC089;
  --success-dark: #6FA059;
  --warning: var(--color-warning);
  --warning-light: #F4D796;
  --warning-dark: #D4B776;
  --error: var(--color-danger);
  --error-light: #D48080;
  --error-dark: #B46060;
  --gray-50: var(--color-gray-50);
  --gray-100: var(--color-gray-100);
  --gray-200: var(--color-gray-200);
  --gray-300: var(--color-gray-300);
  --gray-400: var(--color-gray-400);
  --gray-500: var(--color-gray-500);
  --gray-600: var(--color-gray-600);
  --gray-700: var(--color-gray-700);
  --gray-800: var(--color-gray-800);
  --gray-900: var(--color-gray-900);
  --font-size-caption: var(--font-size-xs);
  --font-size-body-sm: var(--font-size-sm);
  --font-size-body: var(--font-size-base);
  --font-size-h4: var(--font-size-lg);
  --font-size-h3: var(--font-size-xl);
  --font-size-h2: var(--font-size-2xl);
  --font-size-h1: var(--font-size-3xl);
  --font-weight-regular: var(--font-weight-normal);
}

/* ============================================================
   深色模式覆盖
   作用于：page.dark-mode + .dark-mode + .force-dark
   ============================================================ */
page.dark-mode,
.dark-mode,
.force-dark {
  /* ---------- 中性色（深色暖灰） ---------- */
  --color-gray-50: #1C1917;
  --color-gray-100: #292524;
  --color-gray-200: #3E3833;
  --color-gray-300: #57534E;
  --color-gray-400: #78716C;
  --color-gray-500: #A8A29E;
  --color-gray-600: #D4CFC6;
  --color-gray-700: #E8E4DE;
  --color-gray-800: #F5F3F0;
  --color-gray-900: #FAF9F7;

  /* ---------- 语义化 Token - Dark ---------- */
  --color-bg-page: #1C1917;
  --color-bg-card: #292524;
  --color-bg-card-elevated: #3E3833;
  --color-bg-popover: #3E3833;
  --color-bg-toast: #44403C;
  --color-bg-input: #3E3833;
  --color-bg-button: #D4BC99;
  --color-bg-overlay: rgba(0, 0, 0, 0.6);

  --color-text-primary: #F5F3F0;
  --color-text-secondary: #A8A29E;
  --color-text-muted: #A8A29E;
  --color-text-inverse: #1C1917;
  --color-text-link: #D4BC99;

  /* ---------- 功能色（深色覆盖） ---------- */
  --color-primary: #D4BC99;
  --color-warning: #E4C786;

  --color-border-default: #3E3833;
  --color-border-divider: #3E3833;
  --color-border-focus: #D4BC99;

  --color-shadow: rgba(0, 0, 0, 0.3);
  --color-shadow-ambient: rgba(0, 0, 0, 0.2);

  --color-state-success-bg: #2A3D24;
  --color-state-success-text: #8BC476;
  --color-state-warning-bg: #3D3420;
  --color-state-warning-text: #D4B86A;
  --color-state-error-bg: #3D2020;
  --color-state-error-text: #E08080;

  /* ---------- 旧变量兼容（深色覆盖） ---------- */
  --warning: var(--color-warning);

  /* ---------- 旧变量兼容别名（深色覆盖） ---------- */
  --gray-50: var(--color-bg-page);
  --gray-100: var(--color-bg-card);
  --gray-200: var(--color-border-default);
  --gray-300: #57534E;
  --gray-400: #78716C;
  --gray-500: #A8A29E;
  --gray-600: #D4CFC6;
  --gray-700: #E8E4DE;
  --gray-800: #F5F3F0;
  --gray-900: var(--color-text-primary);
}

/* ============================================================
   系统媒体查询兜底
   无手动设置时，跟随系统 prefers-color-scheme
   ============================================================ */
@media (prefers-color-scheme: dark) {
  page:not(.force-light):not(.force-dark) {
    --color-gray-50: #1C1917;
    --color-gray-100: #292524;
    --color-gray-200: #3E3833;
    --color-gray-300: #57534E;
    --color-gray-400: #78716C;
    --color-gray-500: #A8A29E;
    --color-gray-600: #D4CFC6;
    --color-gray-700: #E8E4DE;
    --color-gray-800: #F5F3F0;
    --color-gray-900: #FAF9F7;

    --color-bg-page: #1C1917;
    --color-bg-card: #292524;
    --color-bg-card-elevated: #3E3833;
    --color-bg-popover: #3E3833;
    --color-bg-toast: #44403C;
    --color-bg-input: #3E3833;
    --color-bg-button: #D4BC99;
    --color-bg-overlay: rgba(0, 0, 0, 0.6);

    --color-text-primary: #F5F3F0;
    --color-text-secondary: #A8A29E;
    --color-text-muted: #A8A29E;
    --color-text-inverse: #1C1917;
    --color-text-link: #D4BC99;

    --color-border-default: #3E3833;
    --color-border-divider: #3E3833;
    --color-border-focus: #D4BC99;

    --color-shadow: rgba(0, 0, 0, 0.3);
    --color-shadow-ambient: rgba(0, 0, 0, 0.2);

    --color-state-success-bg: #2A3D24;
    --color-state-success-text: #8BC476;
    --color-state-warning-bg: #3D3420;
    --color-state-warning-text: #D4B86A;
    --color-state-error-bg: #3D2020;
    --color-state-error-text: #E08080;

    /* ---------- 功能色（深色覆盖） ---------- */
    --color-primary: #D4BC99;
    --color-warning: #E4C786;

    --gray-50: var(--color-bg-page);
    --gray-100: var(--color-bg-card);
    --gray-200: var(--color-border-default);
    --gray-300: #57534E;
    --gray-400: #78716C;
    --gray-500: #A8A29E;
    --gray-600: #D4CFC6;
    --gray-700: #E8E4DE;
    --gray-800: #F5F3F0;
    --gray-900: var(--color-text-primary);

    /* ---------- 旧变量兼容（深色覆盖） ---------- */
    --warning: var(--color-warning);
  }
}

/* ============================================================
   全局样式重置
   ============================================================ */

view, text, button, input, textarea, image {
  box-sizing: border-box;
}

page {
  color: var(--color-text-primary);
  background-color: var(--color-bg-page);
  font-size: var(--font-size-base);
  line-height: var(--line-height-normal);
}

/* ========== 工具类 ========== */

.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-secondary); }
.text-success { color: var(--color-success); }
.text-warning { color: var(--color-warning); }
.text-danger { color: var(--color-danger); }
.text-muted { color: var(--color-text-muted); }

.bg-primary { background-color: var(--color-primary); }
.bg-primary-light { background-color: var(--color-primary-light); }
.bg-success { background-color: var(--color-success); }
.bg-warning { background-color: var(--color-warning); }
.bg-danger { background-color: var(--color-danger); }

/* 状态类（供 JS 组件从硬编码颜色迁移到 class 驱动） */
.status-success {
  color: var(--color-state-success-text);
  background-color: var(--color-state-success-bg);
}

.status-warning {
  color: var(--color-state-warning-text);
  background-color: var(--color-state-warning-bg);
}

.status-danger {
  color: var(--color-state-error-text);
  background-color: var(--color-state-error-bg);
}

.mt-sm { margin-top: var(--spacing-sm); }
.mt-md { margin-top: var(--spacing-md); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-sm); }
.mb-md { margin-bottom: var(--spacing-md); }
.mb-lg { margin-bottom: var(--spacing-lg); }
.p-sm { padding: var(--spacing-sm); }
.p-md { padding: var(--spacing-md); }
.p-lg { padding: var(--spacing-lg); }

.rounded-sm { border-radius: var(--radius-sm); }
.rounded-md { border-radius: var(--radius-md); }
.rounded-lg { border-radius: var(--radius-lg); }
.rounded-full { border-radius: var(--radius-full); }

.shadow-sm { box-shadow: var(--shadow-sm); }
.shadow-md { box-shadow: var(--shadow-md); }
.shadow-lg { box-shadow: var(--shadow-lg); }
