/* ============================================
   规划页面设计系统
   ============================================ */

/* ---- 页面容器 ---- */
.planning-container {
  padding: 24rpx 32rpx 48rpx;
  min-height: 100vh;
  background: var(--color-bg-page);
}

/* ---- 页面标题 ---- */
.page-header {
  margin-bottom: 32rpx;
}

.game-name {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--color-text-primary);
  line-height: 1.2;
  display: block;
}

.page-subtitle {
  font-size: 28rpx;
  font-weight: 400;
  color: var(--color-text-secondary);
  line-height: 1.4;
  margin-top: 8rpx;
  display: block;
}

/* ---- Section 标题（带装饰条） ---- */
.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
  flex-shrink: 0;
}

/* ---- 通用卡片 ---- */
.section-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

/* ---- 目标卡片（强调） ---- */
.target-card {
  background: var(--color-bg-card);
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid var(--color-primary);
  box-shadow: 0 4rpx 16rpx var(--color-shadow);
}

/* ---- 目标 Chip 列表 ---- */
.target-chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.target-chip {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border-divider);
  position: relative;
}

.chip-type {
  padding: 4rpx 10rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: 6rpx;
  font-size: 20rpx;
  font-weight: 600;
}

.chip-name {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-primary);
}

.chip-rank {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.chip-pity {
  font-size: 20rpx;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.chip-pity.big-pity {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.chip-pity.small-pity {
  background: var(--color-gray-100);
  color: var(--color-text-muted);
}

.chip-delete {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 4rpx;
}

.chip-delete-icon {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ---- 添加目标按钮 ---- */
.add-target-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background: var(--color-bg-page);
  border-radius: 16rpx;
  border: 2rpx dashed var(--color-primary);
}

.add-target-icon {
  font-size: 32rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.add-target-text {
  font-size: 28rpx;
  color: var(--color-primary);
  font-weight: 600;
}

/* ---- 表单 ---- */
.target-form {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--color-border-divider);
}

.form-group {
  margin-bottom: 24rpx;
}

.form-group-inline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.form-label {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--color-text-secondary);
  margin-bottom: 12rpx;
  display: block;
}

.form-group-inline .form-label {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

/* ---- 类型选择器 ---- */
.type-selector {
  display: flex;
  gap: 16rpx;
}

.type-option {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border-divider);
}

.type-option.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.type-option-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.type-option.active .type-option-text {
  color: var(--color-text-inverse);
}

/* ---- 等级选择按钮 ---- */
.rank-selector {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.rank-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border-divider);
  display: flex;
  align-items: center;
  justify-content: center;
}

.rank-btn.active {
  background: var(--color-primary);
  border-color: var(--color-primary);
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.rank-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.rank-btn.active .rank-btn-text {
  color: var(--color-text-inverse);
}

/* ---- 卡池时间 ---- */
.date-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.date-picker {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-page);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.date-separator {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
}

/* ---- 按钮 ---- */
.form-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 32rpx;
}

.btn-primary {
  width: 100%;
  height: 96rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 700;
  text-align: center;
  border: none;
  box-shadow: 0 4rpx 12rpx var(--color-shadow);
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-primary::after {
  border: none;
}

.btn-secondary {
  width: 100%;
  height: 80rpx;
  background: var(--color-bg-page);
  color: var(--color-text-primary);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: 2rpx solid var(--color-border-divider);
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-secondary::after {
  border: none;
}



.hint-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-top: 16rpx;
  display: block;
  line-height: 1.5;
}

/* ---- 资源输入 ---- */
.resource-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.resource-row:last-child {
  margin-bottom: 0;
}

.resource-label-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.resource-icon {
  width: 40rpx;
  height: 40rpx;
}

.resource-name {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.resource-input {
  width: 200rpx;
  text-align: right;
}

/* ---- 概率展示 ---- */
.probability-card {
  text-align: center;
}

.target-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.target-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: var(--color-gray-100);
  border-radius: 8rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.probability-display {
  padding: 24rpx 0 32rpx;
}

.target-prob-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 24rpx;
  padding: 0 16rpx;
}

.target-prob-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 20rpx;
  background: var(--color-bg-page);
  border-radius: 10rpx;
}

.target-prob-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.target-prob-value {
  font-size: 28rpx;
  font-weight: 700;
}

.target-prob-guarantee {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.target-prob-guarantee.big-pity {
  background: var(--color-primary-light);
  color: var(--color-primary);
}

.target-prob-guarantee.small-pity {
  background: var(--color-gray-100);
  color: var(--color-text-muted);
}

.probability-number {
  font-size: 96rpx;
  font-weight: 800;
  color: var(--color-primary);
  line-height: 1;
}

.probability-label {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 12rpx;
  display: block;
}

.pulls-info-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid var(--color-border-divider);
}

.pulls-info-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.pulls-info-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.pulls-info-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.pulls-info-value.success {
  color: var(--color-success);
}

.pulls-info-value.danger {
  color: var(--color-danger);
}

.pulls-info-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-border-divider);
}

/* ---- 折叠区域 ---- */
.collapsible-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.collapsible-header .section-title {
  margin-bottom: 0;
}

.toggle-icon {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chart-content {
  margin-top: 24rpx;
}

.empty-hint {
  text-align: center;
  padding: 32rpx 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* ---- 攒抽预测折叠态 ---- */
.prediction-summary {
  margin-top: 24rpx;
}

.metric-grid {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.metric-card {
  flex: 1;
  background: var(--color-bg-page);
  border-radius: 16rpx;
  padding: 24rpx 12rpx;
  text-align: center;
}

.metric-value {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1.2;
}

.metric-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  display: block;
  font-weight: 500;
}

.pool-date-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: var(--color-bg-page);
  border-radius: 12rpx;
}

.pool-date-info.empty {
  background: var(--color-state-warning-bg);
}

.pool-date-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.pool-date-value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.pool-date-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* ---- 攒抽预测展开态 ---- */
.pool-settings-content {
  margin-top: 24rpx;
}

.pool-meta {
  display: flex;
  gap: 24rpx;
  margin: 16rpx 0 24rpx;
}

.pool-meta-item {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.income-section {
  margin-bottom: 24rpx;
}

.income-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.income-row:last-child {
  margin-bottom: 0;
}

.income-input-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.income-input {
  width: 160rpx;
  text-align: right;
}

.income-unit {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  min-width: 100rpx;
  text-align: left;
}

/* ---- 时间线 ---- */
.timeline-section {
  margin-top: 24rpx;
}

.timeline-track {
  position: relative;
  height: 8rpx;
  background: var(--color-border-divider);
  border-radius: 4rpx;
  margin: 48rpx 16rpx 32rpx;
}

.timeline-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #7FB069);
  border-radius: 4rpx;
}

.timeline-marker {
  position: absolute;
  top: -28rpx;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.timeline-marker::before {
  content: '';
  width: 20rpx;
  height: 20rpx;
  background: var(--color-bg-card);
  border: 4rpx solid var(--color-primary);
  border-radius: 50%;
}

.marker-label {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  white-space: nowrap;
}

.marker-value {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-primary);
  white-space: nowrap;
}

.timeline-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.timeline-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  background: var(--color-bg-page);
  border-radius: 8rpx;
}

.timeline-day {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.timeline-arrow {
  font-size: 22rpx;
  color: var(--color-primary);
}

.timeline-prob {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
}

/* ---- 建议框 ---- */
.advice-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 24rpx;
  padding: 20rpx;
  background: var(--color-gray-100);
  border-radius: 12rpx;
}

.advice-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.advice-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  flex: 1;
}

/* ---- 版本信息 ---- */
.version-section {
  padding: 16rpx 0;
  text-align: center;
}

.version-text {
  font-size: 22rpx;
  color: var(--color-text-muted);
  display: block;
}

.version-warning {
  font-size: 22rpx;
  color: var(--color-danger);
  margin-top: 8rpx;
  display: block;
}
