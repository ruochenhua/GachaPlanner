<custom-nav-bar title="规划" />
<view class="{{themeClass}} planning-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="game-name">{{gameName}}</text>
    <text class="page-subtitle">资源管理</text>
  </view>

  <!-- 目标设定区域（核心卡片） -->
  <view class="target-card" id="target-section">
    <view class="section-title">设定目标</view>

    <!-- 已有目标 Chip 列表 -->
    <view class="target-chip-list" wx:if="{{targets.length > 0}}">
      <view
        class="target-chip"
        wx:for="{{targets}}"
        wx:key="id"
        data-index="{{index}}"
        bindtap="onEditTarget"
      >
        <text class="chip-type">{{item.typeLabel}}</text>
        <text class="chip-name">{{item.name}}</text>
        <text class="chip-rank">{{item.desiredRank}}{{item.rankUnit}}</text>
        <text class="chip-pity {{item.isGuaranteed ? 'big-pity' : 'small-pity'}}">{{item.isGuaranteed ? '大' : '小'}}保{{item.currentPity}}</text>
        <view class="chip-delete" catchtap="onDeleteTargetChip" data-index="{{index}}">
          <text class="chip-delete-icon">✕</text>
        </view>
      </view>
    </view>

    <!-- 添加目标按钮 -->
    <view class="add-target-btn" bindtap="onShowTargetForm" wx:if="{{!showTargetForm}}">
      <text class="add-target-icon">+</text>
      <text class="add-target-text">添加目标</text>
    </view>

    <!-- 目标表单 -->
    <view class="target-form" wx:if="{{showTargetForm}}">
      <!-- 目标名称 -->
      <view class="form-group">
        <text class="form-label">目标名称</text>
        <input
          class="form-input"
          type="text"
          value="{{targetForm.name}}"
          placeholder="如：胡桃、护摩之杖"
          bindinput="onTargetNameChange"
        />
      </view>

      <!-- 目标类型 -->
      <view class="form-group">
        <text class="form-label">目标类型</text>
        <view class="type-selector">
          <view
            class="type-option {{targetForm.type === item.key ? 'active' : ''}}"
            wx:for="{{targetTypeOptions}}"
            wx:key="key"
            data-type="{{item.key}}"
            bindtap="onTargetTypeChange"
          >
            <text class="type-option-text">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- 期望等级 -->
      <view class="form-group">
        <text class="form-label">期望{{targetForm.type === 'weapon' ? '精炼' : '命座'}}</text>
        <view class="rank-selector">
          <view
            class="rank-btn {{targetForm.desiredRank === item ? 'active' : ''}}"
            wx:for="{{rankOptions}}"
            wx:key="*this"
            data-rank="{{item}}"
            bindtap="onTargetRankChange"
          >
            <text class="rank-btn-text">{{item}}</text>
          </view>
        </view>
      </view>

      <!-- 当前保底计数 -->
      <view class="form-group">
        <text class="form-label">已垫抽数</text>
        <input
          class="form-input"
          type="number"
          value="{{targetForm.currentPity}}"
          placeholder="0"
          bindinput="onTargetCurrentPityChange"
        />
      </view>

      <!-- 大保底 -->
      <view class="form-group form-group-inline">
        <text class="form-label">大保底</text>
        <switch checked="{{targetForm.isGuaranteed}}" bindchange="onTargetGuaranteedChange" color="#C4A77D" />
      </view>

      <!-- 卡池时间 -->
      <view class="form-group">
        <text class="form-label">卡池时间</text>
        <view class="date-row">
          <picker mode="date" value="{{targetForm.poolStartDate}}" bindchange="onTargetPoolStartDateChange">
            <view class="date-picker">
              <text>{{targetForm.poolStartDate || '开始日期'}}</text>
            </view>
          </picker>
          <text class="date-separator">~</text>
          <picker mode="date" value="{{targetForm.poolEndDate}}" bindchange="onTargetPoolEndDateChange">
            <view class="date-picker">
              <text>{{targetForm.poolEndDate || '结束日期'}}</text>
            </view>
          </picker>
        </view>
      </view>

      <!-- 表单操作 -->
      <view class="form-actions">
        <button class="btn-primary" bindtap="onSaveTarget">
          {{targetEditMode ? '更新目标' : '保存目标'}}
        </button>
        <button class="btn-secondary" bindtap="onCancelTargetForm" wx:if="{{targetEditMode}}">
          取消
        </button>
      </view>
    </view>
  </view>

  <!-- 资源输入 -->
  <view class="section-card">
    <view class="section-title">我的资源</view>
    <block wx:for="{{resourceTypes}}" wx:key="key">
      <view class="resource-row">
        <view class="resource-label-wrap">
          <image wx:if="{{item.icon}}" class="resource-icon" src="{{item.icon}}" mode="aspectFit" />
          <text class="resource-name">{{item.name}}</text>
        </view>
        <input
          class="form-input resource-input"
          type="number"
          value="{{resources[item.key] || 0}}"
          placeholder="0"
          data-key="{{item.key}}"
          bindinput="onResourceChange"
        />
      </view>
    </block>
  </view>

  <!-- 达成概率 -->
  <view class="section-card probability-card">
    <view class="section-title">达成概率</view>

    <!-- 目标标签 -->
    <view class="target-tags" wx:if="{{targetSummary}}">
      <text class="target-tag" wx:for="{{targetSummary}}" wx:key="*this">{{item}}</text>
    </view>

    <!-- 概率大数字 -->
    <view class="probability-display">
      <text class="probability-number">{{probabilityText}}</text>
      <text class="probability-label">综合达成概率</text>
    </view>

    <!-- 各目标概率 -->
    <view class="target-prob-list" wx:if="{{targetProbabilities.length > 0}}">
      <view class="target-prob-item" wx:for="{{targetProbabilities}}" wx:key="name">
        <text class="target-prob-name">{{item.name}}</text>
        <text class="target-prob-guarantee {{item.isGuaranteed ? 'big-pity' : 'small-pity'}}">{{item.isGuaranteed ? '大保底' : '小保底'}}</text>
        <text class="target-prob-value" style="color: {{item.probability >= 0.8 ? '#7FB069' : item.probability >= 0.5 ? '#F5A623' : '#C47070'}};">{{item.probabilityText}}</text>
      </view>
    </view>

    <!-- 抽数信息 -->
    <view class="pulls-info-row">
      <view class="pulls-info-item">
        <text class="pulls-info-label">当前可抽</text>
        <text class="pulls-info-value">{{currentPulls}}抽</text>
      </view>
      <view class="pulls-info-divider"></view>
      <view class="pulls-info-item">
        <text class="pulls-info-label">需要抽数</text>
        <text class="pulls-info-value {{neededPulls > currentPulls ? 'danger' : 'success'}}">{{neededPulls}}抽</text>
      </view>
    </view>
  </view>

  <!-- 概率分布（默认折叠） -->
  <view class="section-card">
    <view class="collapsible-header" bindtap="toggleProbabilityChart">
      <view class="section-title">概率分布</view>
      <text class="toggle-icon">{{showProbabilityChart ? '▼' : '▶'}}</text>
    </view>
    <view class="chart-content" wx:if="{{showProbabilityChart}}">
      <view class="chart-container" wx:if="{{calculatedDistribution.length > 0}}">
        <probability-chart
          distribution="{{calculatedDistribution}}"
          current-pulls="{{currentPulls}}"
          probability-timeline="{{probabilityTimeline}}"
          optimal-wait-days="{{optimalWaitDays}}"
          final-pulls="{{finalPulls}}"
          game-config="{{gameConfig}}"
        />
      </view>
      <view class="empty-hint" wx:else>
        <text>请输入资源数量查看概率分布</text>
      </view>
    </view>
  </view>

  <!-- 攒抽预测（默认折叠） -->
  <view class="section-card">
    <view class="collapsible-header" bindtap="togglePoolSettings">
      <view class="section-title">攒抽预测</view>
      <text class="toggle-icon">{{showPoolSettings ? '▼' : '▶'}}</text>
    </view>

    <!-- 折叠态：指标卡片 -->
    <view class="prediction-summary" wx:if="{{!showPoolSettings}}">
      <view class="metric-grid" wx:if="{{poolStartDate && poolEndDate}}">
        <view class="metric-card">
          <text class="metric-value">{{probabilityText}}</text>
          <text class="metric-label">当前概率</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{finalProbabilityText}}</text>
          <text class="metric-label">最终概率</text>
        </view>
        <view class="metric-card">
          <text class="metric-value">{{remainingDays}}天</text>
          <text class="metric-label">距离卡池结束</text>
        </view>
      </view>
      <view class="pool-date-info" wx:if="{{targetForm.poolStartDate || targetForm.poolEndDate}}">
        <text class="pool-date-label">目标卡池</text>
        <text class="pool-date-value">{{targetForm.poolStartDate || '--'}} ~ {{targetForm.poolEndDate || '--'}}</text>
      </view>
      <view class="empty-hint" wx:else>
        <text>请设定目标卡池时间查看攒抽预测</text>
      </view>
    </view>

    <!-- 展开态 -->
    <view class="pool-settings-content" wx:if="{{showPoolSettings}}">
      <view class="pool-date-info" wx:if="{{targetForm.poolStartDate || targetForm.poolEndDate}}">
        <text class="pool-date-label">目标卡池</text>
        <text class="pool-date-value">{{targetForm.poolStartDate || '--'}} ~ {{targetForm.poolEndDate || '--'}}</text>
      </view>
      <view class="pool-date-info empty" wx:else>
        <text class="pool-date-hint">请在目标设定中设置卡池时间</text>
      </view>

      <view class="pool-meta" wx:if="{{poolDays > 0}}">
        <text class="pool-meta-item">卡池时长 {{poolDays}}天</text>
        <text class="pool-meta-item">剩余 {{remainingDays}}天</text>
      </view>

      <!-- 收入输入 -->
      <view class="income-section">
        <view class="income-row">
          <text class="form-label">每日收入</text>
          <view class="income-input-wrap">
            <input
              class="form-input income-input"
              type="number"
              value="{{dailyIncome}}"
              placeholder="0"
              bindinput="onDailyIncomeChange"
            />
            <text class="income-unit">{{resourceUnit}}/天</text>
          </view>
        </view>
        <view class="income-row">
          <text class="form-label">其他获取</text>
          <view class="income-input-wrap">
            <input
              class="form-input income-input"
              type="number"
              value="{{otherIncome}}"
              placeholder="0"
              bindinput="onOtherIncomeChange"
            />
            <text class="income-unit">{{resourceUnit}}</text>
          </view>
        </view>
      </view>

      <!-- 时间线 -->
      <view class="timeline-section" wx:if="{{probabilityTimeline.length > 0}}">
        <view class="timeline-track">
          <view class="timeline-fill" style="width: 100%;"></view>
          <view class="timeline-marker timeline-start" style="left: 0%;">
            <text class="marker-label">今天</text>
            <text class="marker-value">{{probabilityText}}</text>
          </view>
          <view class="timeline-marker timeline-end" style="left: 100%;">
            <text class="marker-label">结束</text>
            <text class="marker-value">{{finalProbabilityText}}</text>
          </view>
        </view>

        <view class="timeline-list">
          <view class="timeline-item" wx:for="{{probabilityTimeline}}" wx:key="day" wx:if="{{item.day % 5 === 0 || item.day === probabilityTimeline.length - 1}}">
            <text class="timeline-day">第{{item.day}}天</text>
            <text class="timeline-arrow">→</text>
            <text class="timeline-prob">{{item.probabilityText}}</text>
          </view>
        </view>
      </view>

      <!-- 建议 -->
      <view class="advice-box" wx:if="{{waitAdvice}}">
        <text class="advice-icon">💡</text>
        <text class="advice-text">{{waitAdvice}}</text>
      </view>
    </view>
  </view>

  <!-- 版本信息（弱化） -->
  <view class="version-section">
    <text class="version-text">数据版本 v{{dataVersion}} · {{updatedAt}}</text>
    <text class="version-warning" wx:if="{{isDataOutdated}}">数据可能过期，请核对官方公告</text>
  </view>
</view>
