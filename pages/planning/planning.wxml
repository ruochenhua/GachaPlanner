<!--pages/planning/planning.wxml-->
<view class="planning-container">
  <view class="page-header">
    <text class="game-name">{{gameName}}</text>
    <text class="page-title">资源管理</text>
  </view>

  <!-- 版本信息区域 -->
  <view class="version-info-section">
    <view class="version-info-item">
      <text class="version-label">📋 数据版本：</text>
      <text class="version-value">v{{dataVersion}}</text>
    </view>
    <view class="version-info-item">
      <text class="version-label">📅 更新日期：</text>
      <text class="version-value">{{updatedAt}}</text>
    </view>
    <!-- 过期提示 -->
    <view class="outdated-warning" wx:if="{{isDataOutdated}}">
      <text class="warning-icon">⚠️</text>
      <text class="warning-text">数据可能过期，请核对官方公告</text>
    </view>
  </view>

  <!-- 保底状态设置 -->
  <view class="pity-status-section" wx:if="{{gameConfig.guaranteeRate}}">
    <view class="section-title">🎯 保底状态</view>
    <view class="pity-status-row">
      <view class="pity-status-item">
        <text class="pity-label">当前抽数</text>
        <input
          class="pity-input"
          type="number"
          value="{{currentPity}}"
          placeholder="0"
          bindinput="onCurrentPityChange"
        />
        <text class="pity-unit">抽</text>
      </view>
      <view class="pity-status-item">
        <text class="pity-label">大保底</text>
        <switch checked="{{isGuaranteed}}" bindchange="onGuaranteedChange" color="#C4A77D" />
      </view>
    </view>
    <view class="pity-hint">
      <text class="hint-text">开启大保底表示上次5星歪了，下次5星必定是UP角色</text>
    </view>
  </view>

  <view class="resource-input-section">
    <view class="section-title">💰 我的资源</view>
    <block wx:for="{{resourceTypes}}" wx:key="key">
      <resource-input
        resource-key="{{item.key}}"
        resource-name="{{item.name}}"
        resource-icon="{{item.icon}}"
        value="{{resources[item.key] || 0}}"
        min="{{0}}"
        max="{{item.max}}"
        step="{{item.step}}"
        bind:change="onResourceChange"
      />
    </block>
  </view>

  <!-- 卡池时间设置区域 -->
  <view class="pool-settings-section">
    <view class="section-header" bindtap="togglePoolSettings">
      <text class="section-title">📅 卡池时间设置</text>
      <text class="toggle-icon">{{showPoolSettings ? '▼' : '▶'}}</text>
    </view>

    <view class="pool-settings-content" wx:if="{{showPoolSettings}}">
      <view class="date-row">
        <view class="date-item">
          <text class="date-label">开始日期</text>
          <picker mode="date" value="{{poolStartDate}}" bindchange="onPoolStartDateChange">
            <view class="date-picker">
              <text>{{poolStartDate || '请选择'}}</text>
            </view>
          </picker>
        </view>
        <view class="date-item">
          <text class="date-label">结束日期</text>
          <picker mode="date" value="{{poolEndDate}}" bindchange="onPoolEndDateChange">
            <view class="date-picker">
              <text>{{poolEndDate || '请选择'}}</text>
            </view>
          </picker>
        </view>
      </view>

      <view class="pool-info" wx:if="{{poolDays > 0}}">
        <text class="pool-info-item">卡池时长: {{poolDays}}天</text>
        <text class="pool-info-item">剩余: {{remainingDays}}天</text>
      </view>

      <view class="daily-income-row">
        <text class="income-label">每日收入</text>
        <input
          class="income-input"
          type="number"
          value="{{dailyIncome}}"
          placeholder="0"
          bindinput="onDailyIncomeChange"
        />
        <text class="income-unit">原石/天</text>
      </view>

      <!-- 其他资源获取（活动、探索等一次性收入） -->
      <view class="other-income-row">
        <text class="income-label">其他获取</text>
        <input
          class="income-input"
          type="number"
          value="{{otherIncome}}"
          placeholder="0"
          bindinput="onOtherIncomeChange"
        />
        <text class="income-unit">原石</text>
      </view>
      <view class="other-income-hint">
        <text class="hint-text">活动奖励、区域探索等一次性资源</text>
      </view>

      <!-- 动态概率预测 -->
      <view class="dynamic-prediction" wx:if="{{probabilityTimeline.length > 0}}">
        <view class="prediction-title">📈 概率预测</view>
        <view class="timeline-preview">
          <view class="timeline-item" wx:for="{{probabilityTimeline}}" wx:key="day" wx:if="{{item.day % 5 === 0 || item.day === probabilityTimeline.length - 1}}">
            <text class="timeline-day">第{{item.day}}天</text>
            <text class="timeline-prob">{{item.probability * 100}}%</text>
          </view>
        </view>
        <view class="wait-advice" wx:if="{{waitAdvice}}">
          <text class="advice-icon">💡</text>
          <text class="advice-text">{{waitAdvice}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 概率展示区域 -->
  <view class="probability-section">
    <view class="section-title">📊 达成概率</view>

    <!-- 主概率显示 -->
    <view class="main-probability">
      <probability-display probability="{{calculatedProbability}}" animated="{{true}}" />
    </view>

    <!-- 当前抽数提示 -->
    <view class="pulls-info" wx:if="{{currentPulls > 0}}">
      <text class="pulls-label">当前可抽：</text>
      <text class="pulls-value">{{currentPulls}}抽</text>
    </view>
  </view>

  <!-- 概率分布图表区域 -->
  <view class="probability-chart-section">
    <view class="section-title">📈 概率分布</view>

    <view class="chart-container" wx:if="{{calculatedDistribution.length > 0}}">
      <probability-chart
        distribution="{{calculatedDistribution}}"
        current-pulls="{{currentPulls}}"
        probability-timeline="{{probabilityTimeline}}"
        optimal-wait-days="{{optimalWaitDays}}"
        final-pulls="{{finalPulls}}"
        game-config="{{gameConfig}}"
      />
    </view>

    <!-- 无数据提示 -->
    <view class="no-data-hint" wx:else>
      <text class="hint-text">请输入资源数量查看概率分布</text>
    </view>

    <!-- 图表说明 -->
    <view class="chart-legend" wx:if="{{calculatedDistribution.length > 0 && finalPulls > 0}}">
      <view class="legend-item">
        <view class="legend-color current"></view>
        <text class="legend-text">当前概率曲线</text>
      </view>
      <view class="legend-item">
        <view class="legend-color final"></view>
        <text class="legend-text">卡池结束时概率曲线</text>
      </view>
    </view>
  </view>
</view>
