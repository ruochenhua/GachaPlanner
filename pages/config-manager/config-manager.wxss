/* pages/config-manager/config-manager.wxss */

.config-manager-container {
  background: var(--color-bg-page);
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 32rpx;
}

/* 游戏头部 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.game-name {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.config-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.config-status.custom {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.config-status.default {
  background: var(--color-border-divider);
  color: var(--color-text-secondary);
}

/* 配置预览 */
.config-preview {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 24rpx;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.preview-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-item .label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.preview-item .value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.detail-button {
  width: 100%;
  height: 64rpx;
  background: var(--color-gray-100);
  color: var(--color-text-secondary);
  font-size: 24rpx;
  border: none;
  border-radius: 8rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 标签页 */
.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-bg-card);
  border-radius: 12rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  transition: all 0.3s;
}

.tab.active {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-weight: 600;
}

/* 面板 */
.panel {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.panel-desc {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

/* 操作按钮 */
.action-button {
  width: 100%;
  height: 88rpx;
  background: var(--color-gray-100);
  color: var(--color-text-primary);
  font-size: 28rpx;
  border: none;
  border-radius: 12rpx;
  margin: 0 0 24rpx;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-button.primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-weight: 600;
}

.action-button.disabled {
  opacity: 0.5;
}

/* 提示 */
.tips {
  background: var(--color-gray-100);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.tips.warning {
  background: var(--color-state-warning-bg);
}

.tips-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 8rpx;
}

/* 导入预览 */
.import-preview {
  background: var(--color-gray-100);
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.preview-game {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-primary);
}

/* 重置区域 */
.reset-section {
  margin-top: 64rpx;
}

.reset-button {
  width: 100%;
  height: 88rpx;
  background: var(--color-bg-card);
  color: var(--color-primary-light);
  font-size: 28rpx;
  border: 2rpx solid var(--color-primary-light);
  border-radius: 12rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}