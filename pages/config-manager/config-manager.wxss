/* pages/config-manager/config-manager.wxss */

.config-manager-container {
  min-height: 100vh;
  background: #FAF9F7;
  padding: 32rpx;
}

/* 游戏头部 */
.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 32rpx;
}

.game-name {
  font-size: 36rpx;
  font-weight: 600;
  color: #2C2520;
}

.config-status {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.config-status.custom {
  background: #C4A77D;
  color: white;
}

.config-status.default {
  background: #E5E0D8;
  color: #7A7168;
}

/* 配置预览 */
.config-preview {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.preview-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 24rpx;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.preview-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.preview-item .label {
  font-size: 24rpx;
  color: #7A7168;
}

.preview-item .value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.detail-button {
  width: 100%;
  height: 64rpx;
  line-height: 64rpx;
  background: #F5F3F0;
  color: #7A7168;
  font-size: 24rpx;
  border: none;
  border-radius: 8rpx;
}

/* 标签页 */
.tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #7A7168;
  transition: all 0.3s;
}

.tab.active {
  background: #C4A77D;
  color: white;
  font-weight: 600;
}

/* 面板 */
.panel {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.panel-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 16rpx;
}

.panel-desc {
  font-size: 24rpx;
  color: #7A7168;
  margin-bottom: 32rpx;
}

/* 操作按钮 */
.action-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #F5F3F0;
  color: #2C2520;
  font-size: 28rpx;
  border: none;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.action-button.primary {
  background: #C4A77D;
  color: white;
  font-weight: 600;
}

.action-button.disabled {
  opacity: 0.5;
}

/* 提示 */
.tips {
  background: #F5F3F0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.tips.warning {
  background: #FFF3E0;
}

.tips-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 16rpx;
}

.tips-item {
  display: block;
  font-size: 22rpx;
  color: #7A7168;
  line-height: 1.6;
  margin-bottom: 8rpx;
}

/* 导入预览 */
.import-preview {
  background: #F5F3F0;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-top: 24rpx;
}

.preview-game {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  font-size: 24rpx;
  color: #2C2520;
}

/* 重置区域 */
.reset-section {
  margin-top: 64rpx;
}

.reset-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: white;
  color: #D4A574;
  font-size: 28rpx;
  border: 2rpx solid #D4A574;
  border-radius: 12rpx;
}