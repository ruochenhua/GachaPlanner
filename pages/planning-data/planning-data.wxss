/* pages/planning-data/planning-data.wxss */
/* 规划数据管理页面样式 */

.container {
  padding: 20rpx;
  min-height: 100vh;
  background-color: var(--color-gray-100);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

/* 数据列表 */
.data-list {
  margin-bottom: 120rpx;
}

.data-item {
  background-color: var(--color-text-inverse);
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx var(--color-shadow);
}

.data-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-name {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-primary);
}

.last-saved {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.data-content {
  background-color: var(--color-gray-100);
  border-radius: 8rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

.data-row {
  display: flex;
  justify-content: flex-start;
  align-items: center;
  margin-bottom: 8rpx;
}

.data-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  min-width: 140rpx;
}

.value {
  font-size: 26rpx;
  color: var(--color-text-primary);
  flex: 1;
}

.data-actions {
  display: flex;
  justify-content: flex-end;
}

.action-btn {
  margin: 0;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: 8rpx;
}

.delete-btn {
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  border: none;
}

.delete-btn::after {
  border: none;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 32rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: var(--color-text-muted);
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: var(--color-text-muted);
}

/* 底部操作区 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: var(--color-gray-100);
  display: flex;
  justify-content: center;
}

.clear-all-btn {
  width: 600rpx;
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  border: none;
}

.clear-all-btn::after {
  border: none;
}

/* 对话框 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: var(--color-bg-overlay);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: var(--color-text-inverse);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 32rpx var(--color-shadow);
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 24rpx;
}

.modal-body {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  text-align: center;
  margin-bottom: 32rpx;
  line-height: 1.6;
}

.modal-buttons {
  display: flex;
  justify-content: space-between;
}

.modal-btn {
  width: 260rpx;
  height: 80rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn {
  background-color: var(--color-gray-100);
  color: var(--color-text-secondary);
  border: none;
  padding: 0;
  margin: 0;
}

.cancel-btn::after {
  border: none;
}

.confirm-btn {
  background-color: var(--color-danger);
  color: var(--color-text-inverse);
  border: none;
  padding: 0;
  margin: 0;
}

.confirm-btn::after {
  border: none;
}
