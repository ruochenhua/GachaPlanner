/* 历史记录详情页样式 */

.detail-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 16px;
  box-sizing: border-box;
}

/* 信息卡片 */
.info-card,
.result-card,
.time-card {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--color-border-divider);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 14px;
  color: var(--color-text-muted);
}

.info-value {
  font-size: 14px;
  color: var(--color-text-primary);
}

/* 结果卡片 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16px;
}

.result-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.result-badge {
  padding: 4px 12px;
  border-radius: 16px;
  font-size: 12px;
}

.result-badge.success {
  background: var(--color-state-success-bg);
  color: var(--color-success);
}

.result-badge.failure {
  background: var(--color-state-error-bg);
  color: var(--color-danger);
}

.result-badge.pending {
  background: var(--color-state-warning-bg);
  color: var(--color-warning);
}

.result-stats {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
}

.stat-item {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.stat-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.stat-value {
  font-size: 18px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.stat-value.primary {
  color: var(--color-primary);
}

/* 时间卡片 */
.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
}

.time-label {
  font-size: 14px;
  color: var(--color-text-muted);
}

.time-value {
  font-size: 14px;
  color: var(--color-text-secondary);
}

/* 表单项 */
.form-item {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
}

.form-label {
  display: block;
  font-size: 14px;
  color: var(--color-text-secondary);
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  font-size: 16px;
  color: var(--color-text-primary);
  background: var(--color-gray-100);
  border: 1px solid var(--color-border-divider);
  border-radius: 8px;
  box-sizing: border-box;
}

.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 40px;
  padding: 0 12px;
  background: var(--color-gray-100);
  border: 1px solid var(--color-border-divider);
  border-radius: 8px;
}

.picker-arrow {
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 结果按钮 */
.result-buttons {
  display: flex;
  gap: 12px;
}

.result-btn {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 16px;
  transition: all 0.2s;
}

.success-btn {
  background: var(--color-bg-card);
  border: 1px solid var(--color-success);
  color: var(--color-success);
}

.success-btn.active {
  background: var(--color-success);
  color: var(--color-text-inverse);
}

.failure-btn {
  background: var(--color-bg-card);
  border: 1px solid var(--color-danger);
  color: var(--color-danger);
}

.failure-btn.active {
  background: var(--color-danger);
  color: var(--color-text-inverse);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 12px;
  margin-top: 24px;
}

.btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 16px;
  border: none;
}

.btn-primary {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.btn-primary:active {
  background: var(--color-primary-dark);
}

.btn-secondary {
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-divider);
  color: var(--color-text-secondary);
}

.btn-secondary:active {
  background: var(--color-gray-100);
}

.btn-danger {
  background: var(--color-bg-card);
  border: 1px solid var(--color-danger);
  color: var(--color-danger);
}

.btn-danger:active {
  background: var(--color-state-error-bg);
}