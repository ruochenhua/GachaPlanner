.overview-container {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 32rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid var(--color-border-divider);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 8rpx;
  height: 32rpx;
  background: var(--color-primary);
  border-radius: 4rpx;
  display: inline-block;
}

.add-btn {
  padding: 8rpx 20rpx;
  background: var(--color-primary);
  border-radius: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: var(--color-text-inverse);
  font-weight: 500;
}

.summary-bar {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-number {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.summary-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.summary-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--color-border-divider);
}

.goals-list-vertical {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.add-goal-card-vertical {
  width: 100%;
  min-height: 120rpx;
  border-radius: 16rpx;
  border: 2rpx dashed var(--color-primary);
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: var(--color-bg-card);
}

.add-icon {
  font-size: 48rpx;
}

.add-label {
  font-size: 26rpx;
  color: var(--color-primary);
}

.simulator-section {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.simulator-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.simulator-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.simulator-toggle {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.simulator-collapsed {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.allocation-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-name {
  font-size: 26rpx;
  color: var(--color-text-primary);
  min-width: 100rpx;
}

.summary-bar-track {
  flex: 1;
  height: 8rpx;
  background: var(--color-border-divider);
  border-radius: 4rpx;
  overflow: hidden;
}

.summary-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 4rpx;
}

.summary-pulls {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  min-width: 80rpx;
  text-align: right;
}

.summary-probability {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-primary);
  min-width: 60rpx;
  text-align: right;
}

.simulator-summary-row {
  padding-top: 16rpx;
  border-top: 1rpx solid var(--color-border-divider);
  margin-top: 8rpx;
}

.summary-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.simulator-expanded {
  display: flex;
  flex-direction: column;
}

.simulator-total {
  padding: 16rpx 0;
  text-align: center;
  border-top: 1rpx solid var(--color-border-divider);
  margin-top: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}

.simulator-hint {
  padding: 12rpx 16rpx;
  background: var(--color-state-success-bg);
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--color-success);
}

.simulator-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
}

.btn-reset {
  font-size: 26rpx;
  color: var(--color-danger);
  padding: 8rpx 16rpx;
}

.strategy-section {
  margin-bottom: 24rpx;
}

.fallback-overview {
  margin-top: 24rpx;
}

.empty-goals {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 28rpx;
  color: var(--color-text-primary);
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  margin-bottom: 24rpx;
  text-align: center;
}

.btn-set-goal {
  padding: 16rpx 40rpx;
  background: var(--color-primary);
  border-radius: 12rpx;
}

.btn-set-goal text {
  font-size: 28rpx;
  color: var(--color-text-inverse);
  font-weight: 500;
}

.games-section {
  margin-bottom: 24rpx;
}

.games-section .section-title {
  margin-bottom: 24rpx;
}

.games-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
}

.game-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.game-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
}

.game-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.game-pulls {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.probability-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.probability-badge.high {
  background: var(--color-state-success-bg);
  color: var(--color-success);
}

.probability-badge.medium {
  background: var(--color-state-warning-bg);
  color: var(--color-warning);
}

.probability-badge.low {
  background: var(--color-state-error-bg);
  color: var(--color-danger);
}

.probability-bar {
  height: 12rpx;
  background: var(--color-border-divider);
  border-radius: 6rpx;
  overflow: hidden;
}

.probability-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 撤销重置按钮 */
.btn-reset.undo {
  color: var(--color-success);
}

/* 空策略提示 */
.empty-strategies {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: var(--color-bg-card);
  border-radius: 16rpx;
}

.empty-strategies .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-strategies .empty-title {
  font-size: 32rpx;
  color: var(--color-text-primary);
  margin-bottom: 8rpx;
}

.empty-strategies .empty-hint {
  font-size: 26rpx;
  color: var(--color-text-muted);
}