.overview-container {
  min-height: 100vh;
  background: #FAF9F7;
  padding: 32rpx;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E5E0D8;
  border-top-color: #C4A77D;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #7A7168;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2520;
}

.add-btn {
  padding: 8rpx 20rpx;
  background: #C4A77D;
  border-radius: 8rpx;
}

.add-text {
  font-size: 26rpx;
  color: white;
  font-weight: 500;
}

.goals-scroll {
  width: 100%;
  margin-bottom: 24rpx;
  white-space: nowrap;
}

.goals-list {
  display: inline-flex;
  gap: 20rpx;
  padding-right: 32rpx;
}

.add-goal-card {
  width: 200rpx;
  min-height: 300rpx;
  border-radius: 16rpx;
  border: 2rpx dashed #C4A77D;
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  flex-shrink: 0;
}

.add-icon {
  font-size: 48rpx;
}

.add-label {
  font-size: 26rpx;
  color: #C4A77D;
}

.simulator-section {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.simulator-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.simulator-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.simulator-toggle {
  font-size: 26rpx;
  color: #7A7168;
}

.simulator-collapsed {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.allocation-summary {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.summary-name {
  font-size: 26rpx;
  color: #2C2520;
  min-width: 100rpx;
}

.summary-bar-track {
  flex: 1;
  height: 8rpx;
  background: #E5E0D8;
  border-radius: 4rpx;
  overflow: hidden;
}

.summary-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 4rpx;
}

.summary-pulls {
  font-size: 24rpx;
  color: #7A7168;
  min-width: 80rpx;
  text-align: right;
}

.summary-probability {
  font-size: 24rpx;
  font-weight: 600;
  color: #C4A77D;
  min-width: 60rpx;
  text-align: right;
}

.simulator-summary-row {
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E0D8;
  margin-top: 8rpx;
}

.summary-text {
  font-size: 24rpx;
  color: #7A7168;
}

.simulator-expanded {
  display: flex;
  flex-direction: column;
}

.simulator-total {
  padding: 16rpx 0;
  text-align: center;
  border-top: 1rpx solid #E5E0D8;
  margin-top: 8rpx;
}

.total-label {
  font-size: 26rpx;
  color: #7A7168;
  font-weight: 500;
}

.simulator-hint {
  padding: 12rpx 16rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.hint-text {
  font-size: 24rpx;
  color: #7CB342;
}

.simulator-actions {
  display: flex;
  justify-content: flex-end;
  padding-top: 16rpx;
}

.btn-reset {
  font-size: 26rpx;
  color: #C47070;
  padding: 8rpx 16rpx;
}

.strategy-section {
  margin-bottom: 24rpx;
}

.fallback-overview {
  margin-top: 24rpx;
}

.empty-goals {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 28rpx;
  color: #2C2520;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #7A7168;
  margin-bottom: 24rpx;
  text-align: center;
}

.btn-set-goal {
  padding: 16rpx 40rpx;
  background: #C4A77D;
  border-radius: 12rpx;
}

.btn-set-goal text {
  font-size: 28rpx;
  color: white;
  font-weight: 500;
}

.games-section {
  margin-bottom: 24rpx;
}

.games-section .section-title {
  margin-bottom: 24rpx;
}

.games-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.game-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.game-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
}

.game-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.game-pulls {
  font-size: 24rpx;
  color: #7A7168;
}

.probability-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.probability-badge.high {
  background: #E8F5E9;
  color: #4CAF50;
}

.probability-badge.medium {
  background: #FFF3E0;
  color: #FF9800;
}

.probability-badge.low {
  background: #FFEBEE;
  color: #F44336;
}

.probability-bar {
  height: 12rpx;
  background: #E5E0D8;
  border-radius: 6rpx;
  overflow: hidden;
}

.probability-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 撤销重置按钮 */
.btn-reset.undo {
  color: #7CB342;
}

/* 空策略提示 */
.empty-strategies {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 32rpx;
  background: white;
  border-radius: 16rpx;
}

.empty-strategies .empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-strategies .empty-title {
  font-size: 32rpx;
  color: #4A4A4A;
  margin-bottom: 8rpx;
}

.empty-strategies .empty-hint {
  font-size: 26rpx;
  color: #999;
}