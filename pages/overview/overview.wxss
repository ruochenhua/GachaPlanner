/* pages/overview/overview.wxss */

.overview-container {
  min-height: 100vh;
  background: #FAF9F7;
  padding: 32rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E5E0D8;
  border-top-color: #C4A77D;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: 28rpx;
  color: #7A7168;
}

/* 总览卡片 */
.summary-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 24rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.summary-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 16rpx;
  background: #F5F3F0;
  border-radius: 12rpx;
}

.summary-item.highlight {
  background: #C4A77D;
}

.summary-item.highlight .summary-label,
.summary-item.highlight .summary-value {
  color: white;
}

.summary-label {
  font-size: 24rpx;
  color: #7A7168;
}

.summary-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #2C2520;
}

/* 策略建议 */
.strategy-advice {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  background: #FFF8E1;
  border-radius: 12rpx;
  border-left: 6rpx solid #C4A77D;
}

.advice-icon {
  font-size: 32rpx;
}

.advice-text {
  flex: 1;
  font-size: 26rpx;
  color: #2C2520;
  line-height: 1.5;
}

/* 游戏列表 */
.games-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  background: white;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #7A7168;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #A8A095;
}

/* 游戏卡片 */
.games-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.game-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.game-card:active {
  transform: scale(0.98);
}

/* 游戏头部 */
.game-header {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.game-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 12rpx;
}

.game-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.game-pulls {
  font-size: 24rpx;
  color: #7A7168;
}

/* 概率徽章 */
.probability-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.probability-badge.high {
  background: #E8F5E9;
  color: #4CAF50;
}

.probability-badge.medium {
  background: #FFF3E0;
  color: #FF9800;
}

.probability-badge.low {
  background: #FFEBEE;
  color: #F44336;
}

/* 概率进度条 */
.probability-bar {
  height: 12rpx;
  background: #E5E0D8;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.probability-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 6rpx;
  transition: width 0.3s;
}

/* 状态行 */
.status-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.status-label {
  font-size: 24rpx;
  color: #7A7168;
}

.status-value {
  font-size: 24rpx;
  font-weight: 600;
}

.status-value.success {
  color: #4CAF50;
}

.status-value.warning {
  color: #FF9800;
}

.status-value.danger {
  color: #F44336;
}

/* 卡片底部 */
.card-footer {
  padding-top: 16rpx;
  border-top: 1rpx solid #E5E0D8;
}

.footer-text {
  font-size: 24rpx;
  color: #C4A77D;
}

/* 说明区域 */
.info-section {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 24rpx;
}

.info-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.info-item {
  font-size: 24rpx;
  color: #7A7168;
  line-height: 1.6;
}