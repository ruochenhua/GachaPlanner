/* 版本列表页面样式 */

.version-list-page {
  min-height: 100vh;
  background: var(--color-bg-page);
  padding: 16px;
  box-sizing: border-box;
}

/* 统计概览卡片 */
.summary-card {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px var(--color-shadow);
}

.summary-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 16px;
}

.summary-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-value {
  font-size: 24px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.stat-item.normal .stat-value {
  color: var(--color-success);
}

.stat-item.warning .stat-value {
  color: var(--color-warning);
}

.stat-item.expired .stat-value {
  color: var(--color-danger);
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 40px;
  font-size: 14px;
  color: var(--color-text-muted);
}

/* 游戏列表 */
.game-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.game-item {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px var(--color-shadow);
}

.game-item:active {
  background: var(--color-gray-100);
}

.game-item.expired {
  border-left: 3px solid var(--color-danger);
}

.game-item.warning {
  border-left: 3px solid var(--color-warning);
}

.game-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12px;
}

.game-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.status-badge {
  font-size: 16px;
}

.version-info {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-label {
  font-size: 14px;
  color: var(--color-text-muted);
}

.info-value {
  font-size: 14px;
  color: var(--color-text-primary);
}

.info-value.expired {
  color: var(--color-warning);
}

.expiry-message {
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border-divider);
  font-size: 12px;
  color: var(--color-warning);
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 60px 20px;
}

.empty-text {
  font-size: 16px;
  color: var(--color-text-muted);
}