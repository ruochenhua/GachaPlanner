<custom-nav-bar title="版本" />
<view class="{{themeClass}} version-list-page">
  <!-- 统计概览 -->
  <view class="summary-card">
    <view class="summary-title">数据版本概览</view>
    <view class="summary-stats">
      <view class="stat-item">
        <text class="stat-value">{{expirySummary.total}}</text>
        <text class="stat-label">游戏总数</text>
      </view>
      <view class="stat-item normal">
        <text class="stat-value">{{expirySummary.normal}}</text>
        <text class="stat-label">数据正常</text>
      </view>
      <view class="stat-item warning">
        <text class="stat-value">{{expirySummary.warning}}</text>
        <text class="stat-label">即将过期</text>
      </view>
      <view class="stat-item expired">
        <text class="stat-value">{{expirySummary.expired}}</text>
        <text class="stat-label">数据过期</text>
      </view>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-state" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>

  <!-- 游戏版本列表 -->
  <view class="game-list" wx:if="{{!loading && gameVersions.length > 0}}">
    <block wx:for="{{gameVersions}}" wx:key="gameId">
      <view
        class="game-item {{item.warningLevel.level}}"
        data-game-id="{{item.gameId}}"
        bindtap="onGameTap"
      >
        <view class="game-header">
          <text class="game-name">{{item.gameName}}</text>
          <view class="status-badge {{item.warningLevel.level}}">
            <text>{{item.warningLevel.icon}}</text>
          </view>
        </view>

        <view class="version-info">
          <view class="info-row">
            <text class="info-label">数据版本</text>
            <text class="info-value">v{{item.version}}</text>
          </view>
          <view class="info-row">
            <text class="info-label">更新日期</text>
            <text class="info-value {{item.expiryResult.isExpired ? 'expired' : ''}}">{{item.updatedAt}}</text>
          </view>
        </view>

        <view class="expiry-message" wx:if="{{item.expiryResult.isExpired}}">
          <text>数据已{{item.expiryResult.daysSinceUpdate}}天未更新，请核对官方公告</text>
        </view>
      </view>
    </block>
  </view>

  <!-- 空数据状态 -->
  <view class="empty-state" wx:if="{{!loading && gameVersions.length === 0}}">
    <text class="empty-text">暂无游戏数据</text>
  </view>
</view>