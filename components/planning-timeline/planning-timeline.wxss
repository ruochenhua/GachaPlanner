/* 规划时间轴组件样式 */

.timeline-container {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 20px;
}

.empty-text {
  font-size: 14px;
  color: #9B9B9B;
}

/* 时间轴滚动区域 */
.timeline-scroll {
  width: 100%;
  white-space: nowrap;
}

.timeline-content {
  display: flex;
  align-items: flex-start;
  padding: 20px 0;
  min-width: 100%;
}

/* 时间轴线 */
.timeline-line {
  position: absolute;
  top: 28px;
  left: 16px;
  right: 16px;
  height: 2px;
  background: #D4D4D4;
  z-index: 0;
}

/* 节点样式 */
.timeline-node {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100px;
  margin-right: 20px;
  padding-top: 16px;
  z-index: 1;
}

.timeline-node:last-child {
  margin-right: 0;
}

/* 节点圆点 */
.node-dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid #C4A77D;
  background: #FFFFFF;
  margin-bottom: 8px;
}

.node-dot.past {
  border-color: #9B9B9B;
  background: #9B9B9B;
}

.node-dot.current {
  width: 20px;
  height: 20px;
  border-color: #7FB069;
  background: #7FB069;
}

.node-dot.future {
  border-color: #C4A77D;
}

.dot-inner {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #FFFFFF;
  position: absolute;
  top: 6px;
  left: 6px;
}

/* 节点内容 */
.node-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px;
  border-radius: 8px;
  background: #FAFAFA;
  min-width: 80px;
}

.node-content:active {
  background: #F5F5F5;
}

.node-date {
  font-size: 12px;
  color: #6B6B6B;
}

.game-badge {
  font-size: 10px;
  color: #C4A77D;
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(196, 167, 125, 0.15);
}

.node-pool {
  font-size: 14px;
  color: #4A4A4A;
  text-align: center;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.node-probability {
  font-size: 12px;
  color: #7FB069;
  font-weight: 500;
}

/* 过去节点灰色 */
.timeline-node.past .node-content {
  opacity: 0.6;
}

.timeline-node.past .node-date,
.timeline-node.past .node-pool,
.timeline-node.past .game-badge {
  color: #9B9B9B;
}

.timeline-node.past .game-badge {
  background: rgba(155, 155, 155, 0.15);
}

.timeline-node.past .node-probability {
  color: #9B9B9B;
}

/* 当前节点高亮 */
.timeline-node.current .node-content {
  background: rgba(127, 176, 105, 0.1);
  border: 1px solid #7FB069;
}

/* 滚动指示器 */
.scroll-indicator {
  text-align: center;
  padding-top: 8px;
}

.indicator-text {
  font-size: 12px;
  color: #9B9B9B;
}