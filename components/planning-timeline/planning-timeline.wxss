/* 规划时间轴组件样式 */

.timeline-container {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  box-shadow: 0 2px 8px var(--color-shadow);
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 20px;
}

.empty-text {
  font-size: 14px;
  color: var(--color-text-muted);
}

/* 时间轴滚动区域 */
.timeline-scroll {
  width: 100%;
  white-space: nowrap;
}

.timeline-content {
  display: flex;
  align-items: flex-start;
  padding: 20px 0;
  min-width: 100%;
}

/* 时间轴线 */
.timeline-line {
  position: absolute;
  top: 28px;
  left: 16px;
  right: 16px;
  height: 2px;
  background: var(--color-gray-300);
  z-index: 0;
}

/* 节点样式 */
.timeline-node {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-width: 100px;
  margin-right: 20px;
  padding-top: 16px;
  z-index: 1;
}

.timeline-node:last-child {
  margin-right: 0;
}

/* 节点圆点 */
.node-dot {
  width: 16px;
  height: 16px;
  border-radius: 50%;
  border: 2px solid var(--color-primary);
  background: var(--color-bg-card);
  margin-bottom: 8px;
}

.node-dot.past {
  border-color: var(--color-text-muted);
  background: var(--color-text-muted);
}

.node-dot.current {
  width: 20px;
  height: 20px;
  border-color: var(--color-success);
  background: var(--color-success);
}

.node-dot.future {
  border-color: var(--color-primary);
}

.dot-inner {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-bg-card);
  position: absolute;
  top: 6px;
  left: 6px;
}

/* 节点内容 */
.node-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 8px;
  border-radius: 8px;
  background: var(--color-bg-page);
  min-width: 80px;
}

.node-content:active {
  background: var(--color-gray-100);
}

.node-date {
  font-size: 12px;
  color: var(--color-text-secondary);
}

.game-badge {
  font-size: 10px;
  color: var(--color-primary);
  padding: 2px 6px;
  border-radius: 4px;
  background: var(--color-primary-light);
}

.node-pool {
  font-size: 14px;
  color: var(--color-text-primary);
  text-align: center;
  max-width: 80px;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.node-probability {
  font-size: 12px;
  color: var(--color-success);
  font-weight: 500;
}

/* 过去节点灰色 */
.timeline-node.past .node-content {
  opacity: 0.6;
}

.timeline-node.past .node-date,
.timeline-node.past .node-pool,
.timeline-node.past .game-badge {
  color: var(--color-text-muted);
}

.timeline-node.past .game-badge {
  background: var(--color-gray-100);
}

.timeline-node.past .node-probability {
  color: var(--color-text-muted);
}

/* 当前节点高亮 */
.timeline-node.current .node-content {
  background: var(--color-state-success-bg);
  border: 1px solid var(--color-success);
}

/* 滚动指示器 */
.scroll-indicator {
  text-align: center;
  padding-top: 8px;
}

.indicator-text {
  font-size: 12px;
  color: var(--color-text-muted);
}