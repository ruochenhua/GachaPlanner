<!--components/overview-card/overview-card.wxml-->
<!-- 总览卡片组件 -->

<view class="overview-card">
  <!-- 总资源展示 -->
  <view class="overview-header">
    <view class="overview-title">
      <text class="title-icon">📊</text>
      <text class="title-text">我的规划总览</text>
    </view>
    <view class="total-resources">
      <text class="resources-label">总抽数</text>
      <text class="resources-value">{{totalResources}}抽</text>
    </view>
  </view>

  <!-- 统计数据 -->
  <view class="overview-stats">
    <view class="stat-item">
      <text class="stat-icon">🎯</text>
      <view class="stat-content">
        <text class="stat-value">{{monthlyPlans}}</text>
        <text class="stat-label">本月规划</text>
      </view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-icon">💰</text>
      <view class="stat-content">
        <text class="stat-value">{{resourceDistribution.length}}</text>
        <text class="stat-label">游戏数量</text>
      </view>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-icon">⚡</text>
      <view class="stat-content">
        <text class="stat-value">{{averageProbability}}%</text>
        <text class="stat-label">平均概率</text>
      </view>
    </view>
  </view>

  <!-- 综合概率展示 -->
  <view class="combined-probability-section" wx:if="{{combinedProbability > 0}}">
    <view class="combined-header">
      <text class="combined-icon">🎯</text>
      <text class="combined-title">综合概率</text>
      <text class="combined-value">{{combinedProbability}}%</text>
    </view>
    <view class="strategy-advice" wx:if="{{strategyAdvice}}">
      <text class="advice-icon">💡</text>
      <text class="advice-text">{{strategyAdvice}}</text>
    </view>
  </view>

  <!-- 资源分配饼图 -->
  <view class="resource-distribution" wx:if="{{resourceDistribution.length > 0}}">
    <view class="distribution-title">资源分配</view>
    <view class="distribution-list">
      <view class="distribution-item" wx:for="{{resourceDistribution}}" wx:key="name">
        <view class="distribution-color" style="background-color: {{item.color || '#C4A77D'}}"></view>
        <text class="distribution-name">{{item.name}}</text>
        <text class="distribution-value">{{item.percentage}}%</text>
      </view>
    </view>
  </view>
</view>