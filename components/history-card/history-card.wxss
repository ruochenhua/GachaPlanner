/* 历史记录卡片组件样式 */

.history-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  transition: transform 0.2s;
}

.history-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.game-name {
  font-size: 14px;
  color: #6B6B6B;
}

.time-text {
  font-size: 12px;
  color: #9B9B9B;
}

/* 卡片主体 */
.card-body {
  margin-bottom: 12px;
}

.pool-name {
  font-size: 16px;
  font-weight: 500;
  color: #4A4A4A;
  margin-bottom: 4px;
}

.target-text {
  font-size: 14px;
  color: #6B6B6B;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.probability-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.probability-label {
  font-size: 12px;
  color: #9B9B9B;
}

.probability-value {
  font-size: 14px;
  font-weight: 500;
  color: #C4A77D;
}

/* 结果徽章 */
.result-badge {
  padding: 4px 12px;
  border-radius: 16px;
  font-size: 12px;
}

.result-badge.success {
  background: rgba(127, 176, 105, 0.15);
  color: #7FB069;
}

.result-badge.failure {
  background: rgba(196, 112, 112, 0.15);
  color: #C47070;
}

.result-badge.pending {
  background: rgba(228, 199, 134, 0.15);
  color: #E4C786;
}

/* 统计信息 */
.card-stats {
  display: flex;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid #E5E5E5;
  font-size: 12px;
  color: #9B9B9B;
}