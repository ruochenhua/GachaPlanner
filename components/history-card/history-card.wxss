/* 历史记录卡片组件样式 */

.history-card {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 12px;
  box-shadow: 0 2px 8px var(--color-shadow);
  transition: transform 0.2s;
}

.history-card:active {
  transform: scale(0.98);
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8px;
}

.game-name {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.time-text {
  font-size: 12px;
  color: var(--color-text-muted);
}

/* 卡片主体 */
.card-body {
  margin-bottom: 12px;
}

.pool-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
  margin-bottom: 4px;
}

.target-text {
  font-size: 14px;
  color: var(--color-text-secondary);
}

/* 卡片底部 */
.card-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.probability-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.probability-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.probability-value {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-primary);
}

/* 结果徽章 */
.result-badge {
  padding: 4px 12px;
  border-radius: 16px;
  font-size: 12px;
}

.result-badge.success {
  background: var(--color-state-success-bg);
  color: var(--color-success);
}

.result-badge.failure {
  background: var(--color-state-error-bg);
  color: var(--color-danger);
}

.result-badge.pending {
  background: var(--color-state-warning-bg);
  color: var(--color-warning);
}

/* 统计信息 */
.card-stats {
  display: flex;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border-divider);
  font-size: 12px;
  color: var(--color-text-muted);
}