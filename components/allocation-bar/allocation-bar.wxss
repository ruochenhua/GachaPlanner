.allocation-bar {
  padding: 24rpx 0;
  border-bottom: 1rpx solid #E5E0D8;
}

.allocation-bar.highlight {
  background-color: #FFF8E1;
  border-radius: 12rpx;
  padding: 24rpx;
}

.bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.probability {
  font-size: 28rpx;
  font-weight: 600;
  color: #C4A77D;
}

.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.step-btn-group {
  display: flex;
  gap: 8rpx;
}

.step-btn {
  min-width: 56rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #E5E0D8;
  border-radius: 8rpx;
  background: white;
}

.step-text {
  font-size: 24rpx;
  color: #2C2520;
  font-weight: 500;
}

.value-display {
  min-width: 100rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #C4A77D;
  border-radius: 8rpx;
  background: white;
  padding: 0 16rpx;
}

.value-text {
  font-size: 32rpx;
  color: #2C2520;
  font-weight: 600;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.percentage-label {
  font-size: 24rpx;
  color: #7A7168;
  min-width: 60rpx;
  text-align: right;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background: #E5E0D8;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 4rpx;
  transition: width 300ms ease;
}