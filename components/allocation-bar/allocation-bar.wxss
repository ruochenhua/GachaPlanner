.allocation-bar {
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--color-border-divider);
}

.allocation-bar.highlight {
  background-color: var(--color-state-warning-bg);
  border-radius: 12rpx;
  padding: 24rpx;
}

.bar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.game-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.probability {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-primary);
}

.controls {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.step-btn-group {
  display: flex;
  gap: 8rpx;
}

.step-btn {
  min-width: 56rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-border-divider);
  border-radius: 8rpx;
  background: var(--color-bg-card);
}

.step-text {
  font-size: 24rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.value-display {
  min-width: 100rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid var(--color-primary);
  border-radius: 8rpx;
  background: var(--color-bg-card);
  padding: 0 16rpx;
}

.value-text {
  font-size: 32rpx;
  color: var(--color-text-primary);
  font-weight: 600;
}

.progress-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.allocation-label {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  min-width: 120rpx;
  text-align: right;
  white-space: nowrap;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background: var(--color-border-divider);
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #C4A77D, #D4B896);
  border-radius: 4rpx;
  transition: width 300ms ease;
}