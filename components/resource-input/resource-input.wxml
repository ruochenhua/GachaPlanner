<!--components/resource-input/resource-input.wxml-->
<!-- 资源输入组件 - 简化版本，优化交互体验 -->

<view class="resource-input">
  <!-- 资源标题 -->
  <view class="resource-header">
    <image
      class="resource-icon"
      src="{{resourceIcon}}"
      mode="aspectFit"
      wx:if="{{resourceIcon}}"
      binderror="onImageError"
    />
    <text class="resource-name">{{resourceName}}</text>
    <text class="resource-value">{{value}}</text>
  </view>

  <!-- 输入控件 -->
  <view class="resource-controls">
    <!-- 主输入框 -->
    <view class="input-row">
      <input
        class="number-input"
        type="number"
        value="{{value}}"
        placeholder="0"
        bindinput="onInputChange"
        bindconfirm="onInputConfirm"
      />
    </view>

    <!-- 快捷调整按钮 -->
    <view class="quick-buttons">
      <!-- 根据资源类型显示不同的快捷按钮 -->
      <block wx:if="{{step >= 100}}">
        <!-- 大数量级资源（原石等） -->
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-1000">-1000</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-100">-100</view>
        <view class="quick-btn reset-btn" bindtap="onReset">清零</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="100">+100</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="1000">+1000</view>
      </block>
      <block wx:elif="{{step >= 10}}">
        <!-- 中等数量级资源 -->
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-100">-100</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-10">-10</view>
        <view class="quick-btn reset-btn" bindtap="onReset">清零</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="10">+10</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="100">+100</view>
      </block>
      <block wx:else>
        <!-- 小数量级资源（纠缠之缘等） -->
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-10">-10</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="-1">-1</view>
        <view class="quick-btn reset-btn" bindtap="onReset">清零</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="1">+1</view>
        <view class="quick-btn" bindtap="onQuickAdd" data-value="10">+10</view>
      </block>
    </view>
  </view>
</view>