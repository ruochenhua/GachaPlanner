/* 资源消耗曲线图表组件样式 */

.resource-curve-chart {
  width: 100%;
  position: relative;
}

.chart-container {
  width: 100%;
  position: relative;
  background-color: var(--color-bg-page);  /* Gray 50 */
  border-radius: 8px;
  overflow: hidden;
}

.chart-canvas {
  width: 100%;
  height: 100%;
}

/* 空数据状态 */
.empty-state {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
  box-sizing: border-box;
}

.empty-text {
  font-size: 14px;
  color: var(--color-text-secondary);  /* Gray 500 */
  margin-bottom: 8px;
}

.empty-hint {
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 图表摘要 */
.chart-summary {
  margin-top: 8px;
  text-align: center;
  padding: 0 16px;
}

.summary-text {
  font-size: 12px;
  color: var(--color-text-secondary);  /* Gray 500 */
  line-height: 1.5;
}

/* Tooltip */
.tooltip {
  position: absolute;
  background-color: var(--color-bg-toast);
  color: var(--color-bg-page);
  padding: 10px 12px;
  border-radius: 6px;
  font-size: 12px;
  pointer-events: none;
  z-index: 10;
  min-width: 120px;
  box-shadow: 0 2px 8px var(--color-shadow);
  transform: translateX(-50%);
}

.tooltip-title {
  display: block;
  font-weight: 600;
  font-size: 13px;
  margin-bottom: 4px;
  color: var(--color-bg-page);
}

.tooltip-game {
  display: block;
  font-size: 11px;
  opacity: 0.8;
  margin-bottom: 6px;
  padding-bottom: 6px;
  border-bottom: 1px solid var(--color-border-divider);
}

.tooltip-date,
.tooltip-pulls,
.tooltip-cost {
  display: block;
  opacity: 0.9;
  margin-top: 4px;
  line-height: 1.4;
}

/* 响应式适配 */
@media screen and (max-width: 320px) {
  .tooltip {
    font-size: 11px;
    padding: 8px 10px;
    min-width: 100px;
  }
}