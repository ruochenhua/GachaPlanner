<view class="onboarding-guide" wx:if="{{show}}" role="region" aria-label="新手引导">
  <swiper
    class="guide-swiper"
    indicator-dots="{{true}}"
    current="{{currentPage}}"
    bindchange="onPageChange"
    duration="{{300}}"
  >
    <swiper-item wx:for="{{pages}}" wx:key="id">
      <view class="guide-page">
        <view class="guide-content">
          <text class="guide-icon">{{item.icon}}</text>
          <text class="guide-title">{{item.title}}</text>
          <text class="guide-description">{{item.description}}</text>
          <text class="guide-highlight" wx:if="{{item.highlight}}">{{item.highlight}}</text>
        </view>
        <view class="guide-actions">
          <view class="skip-btn" wx:if="{{currentPage < totalPages - 1}}" bindtap="onSkip">
            <text>跳过</text>
          </view>
          <view class="start-btn" wx:if="{{currentPage === totalPages - 1}}" bindtap="onComplete">
            <text>开始使用</text>
          </view>
        </view>
        <view class="guide-progress">
          <text class="progress-text">{{currentPage + 1}} / {{totalPages}}</text>
        </view>
      </view>
    </swiper-item>
  </swiper>
</view>
