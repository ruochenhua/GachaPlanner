/* 新手引导组件样式 */

.onboarding-guide {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  background-color: var(--color-bg-overlay);
}

.guide-swiper {
  width: 100%;
  height: 100%;
}

.guide-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 48px;
  padding-bottom: 120px;
  box-sizing: border-box;
  background-color: var(--color-primary-light);
}

/* 内容区域 */
.guide-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48px;
}

.guide-icon {
  font-size: 64px;
  margin-bottom: 24px;
}

.guide-title {
  font-size: 24px;
  font-weight: 600;
  color: var(--color-text-primary);
  text-align: center;
  margin-bottom: 16px;
}

.guide-description {
  font-size: 16px;
  color: var(--color-text-secondary);  /* Gray 600 */
  text-align: center;
  margin-bottom: 12px;
}

.guide-highlight {
  font-size: 14px;
  color: var(--color-primary);  /* Primary */
  text-align: center;
  font-weight: 500;
}

/* 操作按钮 */
.guide-actions {
  width: 100%;
  display: flex;
  justify-content: center;
  position: absolute;
  bottom: 80px;
}

.skip-btn {
  padding: 12px 24px;
  border-radius: 8px;
  background-color: transparent;
  border: 1px solid var(--color-text-secondary);
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.skip-btn text {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.start-btn {
  padding: 12px 32px;
  border-radius: 8px;
  background-color: var(--color-primary);  /* Primary */
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.start-btn text {
  font-size: 16px;
  color: var(--color-text-inverse);
  font-weight: 500;
}

/* 进度指示 */
.guide-progress {
  position: absolute;
  bottom: 40px;
  width: 100%;
  display: flex;
  justify-content: center;
}

.progress-text {
  font-size: 12px;
  color: var(--color-text-secondary);
}

/* 响应式适配 */
@media screen and (max-width: 320px) {
  .guide-page {
    padding: 32px;
  }

  .guide-icon {
    font-size: 48px;
  }

  .guide-title {
    font-size: 20px;
  }
}