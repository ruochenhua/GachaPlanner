.strategy-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.strategy-label {
  font-size: 22rpx;
  color: #7A7168;
  background: #F5F3F0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.strategy-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.recommend-badge {
  background: #FFEBEE;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.recommend-text {
  font-size: 22rpx;
  color: #C47070;
}

.strategy-description {
  font-size: 26rpx;
  color: #7A7168;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

/* 对比区域 */
.comparison-section {
  margin-bottom: 16rpx;
}

.comparison-header {
  margin-bottom: 12rpx;
}

.comparison-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2C2520;
}

.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: #F5F3F0;
  border-radius: 12rpx;
}

.comparison-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comparison-game {
  font-size: 26rpx;
  color: #2C2520;
  min-width: 120rpx;
  flex-shrink: 0;
}

.comparison-detail {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comparison-current {
  font-size: 24rpx;
  color: #7A7168;
}

.comparison-arrow {
  font-size: 24rpx;
  color: #C4A77D;
  font-weight: 600;
}

.comparison-suggested {
  font-size: 24rpx;
  color: #C4A77D;
  font-weight: 600;
}

.comparison-delta {
  min-width: 80rpx;
  text-align: right;
}

.delta-pulls {
  font-size: 24rpx;
  color: #7A7168;
}

.delta-pulls.up {
  color: #4CAF50;
}

.delta-pulls.down {
  color: #C47070;
}

.conclusion {
  margin-bottom: 16rpx;
}

.conclusion-text {
  font-size: 26rpx;
  color: #2C2520;
  font-weight: 500;
}

.top-up-info {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
}

.top-up-text {
  font-size: 26rpx;
  color: #7CB342;
}

.action-section {
  margin-top: 16rpx;
}

.btn-apply {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #C4A77D;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
}
