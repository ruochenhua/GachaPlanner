.strategy-card {
  background: var(--color-bg-card);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
  border: 2rpx solid transparent;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.strategy-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  background: var(--color-gray-100);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.strategy-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.recommend-badge {
  background: var(--color-state-error-bg);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.recommend-text {
  font-size: 22rpx;
  color: var(--color-danger);
}

.strategy-description {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  margin-bottom: 16rpx;
  line-height: 1.5;
}

/* 对比区域 */
.comparison-section {
  margin-bottom: 16rpx;
}

.comparison-header {
  margin-bottom: 12rpx;
}

.comparison-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.comparison-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 16rpx;
  background: var(--color-gray-100);
  border-radius: 12rpx;
}

.comparison-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.comparison-game {
  font-size: 26rpx;
  color: var(--color-text-primary);
  min-width: 120rpx;
  flex-shrink: 0;
}

.comparison-detail {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.comparison-current {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.comparison-arrow {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.comparison-suggested {
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 600;
}

.comparison-delta {
  min-width: 80rpx;
  text-align: right;
}

.delta-pulls {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.delta-pulls.up {
  color: var(--color-success);
}

.delta-pulls.down {
  color: var(--color-danger);
}

.conclusion {
  margin-bottom: 16rpx;
}

.conclusion-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  font-weight: 500;
}

.top-up-info {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: var(--color-state-success-bg);
  border-radius: 8rpx;
}

.top-up-text {
  font-size: 26rpx;
  color: var(--color-success);
}

.action-section {
  margin-top: 16rpx;
}

.btn-apply {
  width: 100%;
  height: 80rpx;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 600;
  text-align: center;
  border: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
