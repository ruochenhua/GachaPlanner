.strategy-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid transparent;
}

.strategy-card.previewing {
  border-color: #C4A77D;
  background: #FFF8E1;
}

.card-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.strategy-label {
  font-size: 22rpx;
  color: #7A7168;
  background: #F5F3F0;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.strategy-name {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
}

.recommend-badge {
  background: #FFEBEE;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.recommend-text {
  font-size: 22rpx;
  color: #C47070;
}

.strategy-description {
  font-size: 26rpx;
  color: #7A7168;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.allocations-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: #F5F3F0;
  border-radius: 12rpx;
}

.allocation-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.allocation-game {
  font-size: 26rpx;
  color: #2C2520;
  flex: 1;
}

.allocation-pulls {
  font-size: 26rpx;
  color: #7A7168;
  margin-right: 24rpx;
}

.allocation-probability {
  font-size: 26rpx;
  font-weight: 600;
  color: #C4A77D;
  min-width: 80rpx;
  text-align: right;
}

.conclusion {
  margin-bottom: 16rpx;
}

.conclusion-text {
  font-size: 26rpx;
  color: #2C2520;
  font-weight: 500;
}

.top-up-info {
  margin-bottom: 16rpx;
  padding: 12rpx 16rpx;
  background: #E8F5E9;
  border-radius: 8rpx;
}

.top-up-text {
  font-size: 26rpx;
  color: #7CB342;
}

.action-section {
  margin-top: 16rpx;
}

.btn-preview {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: white;
  color: #C4A77D;
  border: 2rpx solid #C4A77D;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.preview-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.preview-hint {
  font-size: 24rpx;
  color: #F5A623;
  text-align: center;
}

.btn-apply {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: #C4A77D;
  color: white;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}

.btn-cancel {
  width: 100%;
  height: 72rpx;
  line-height: 72rpx;
  background: white;
  color: #7A7168;
  border: 2rpx solid #E5E0D8;
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
}