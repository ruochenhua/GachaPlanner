<view class="strategy-card">
  <view class="card-header">
    <text class="strategy-label">方案{{['A','B','C','D'][index] || '?'}}</text>
    <text class="strategy-name">{{strategy.name}}</text>
    <view class="recommend-badge" wx:if="{{isRecommended}}">
      <text class="recommend-text">🔥 推荐</text>
    </view>
  </view>

  <view class="strategy-description" wx:if="{{strategy.description}}">
    <text>{{strategy.description}}</text>
  </view>

  <!-- 与现状对比 -->
  <view class="comparison-section">
    <view class="comparison-header">
      <text class="comparison-title">📊 与现状对比</text>
    </view>
    <view class="comparison-list">
      <view class="comparison-item" wx:for="{{comparison}}" wx:key="gameId">
        <text class="comparison-game">{{item.gameName}}</text>
        <view class="comparison-detail">
          <text class="comparison-current">{{item.currentPulls}}抽 {{item.currentProbabilityText}}</text>
          <text class="comparison-arrow">→</text>
          <text class="comparison-suggested">{{item.suggestedPulls}}抽 {{item.suggestedProbabilityText}}</text>
        </view>
        <view class="comparison-delta">
          <text class="delta-pulls {{item.pullDelta > 0 ? 'up' : item.pullDelta < 0 ? 'down' : ''}}">
            {{item.pullDelta > 0 ? '+' : ''}}{{item.pullDelta}}抽
          </text>
        </view>
      </view>
    </view>
  </view>

  <view class="conclusion" wx:if="{{strategy.conclusion}}">
    <text class="conclusion-text">{{strategy.conclusion}}</text>
  </view>

  <view class="top-up-info" wx:if="{{strategy.topUpAmount > 0}}">
    <text class="top-up-text">建议补充 {{strategy.topUpAmount}} 抽</text>
  </view>

  <view class="action-section">
    <button class="btn-apply" bindtap="onApply">应用此方案</button>
  </view>
</view>
