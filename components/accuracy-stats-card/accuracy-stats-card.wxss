/* 准确度统计卡片组件样式 */

.stats-card {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 12px var(--color-shadow);
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 20px;
  font-size: 14px;
  color: var(--color-text-muted);
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 20px;
}

.empty-text {
  font-size: 14px;
  color: var(--color-text-muted);
}

/* 统计内容 */
.stats-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* 命中率展示 */
.hit-rate-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.hit-rate-value {
  display: flex;
  align-items: baseline;
}

.rate-number {
  font-size: 48px;
  font-weight: 600;
}

.rate-percent {
  font-size: 24px;
  font-weight: 400;
  margin-left: 2px;
}

.hit-rate-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: var(--color-text-secondary);
}

.rating-badge {
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 12px;
  color: var(--color-text-inverse);
}

/* 评级颜色类 */
.hit-rate-value.rating-excellent,
.hit-rate-value.rating-excellent .rate-number,
.hit-rate-value.rating-excellent .rate-percent {
  color: var(--color-success);
}

.rating-badge.rating-excellent {
  background-color: var(--color-state-success-bg);
  color: var(--color-state-success-text);
}

.hit-rate-value.rating-good,
.hit-rate-value.rating-good .rate-number,
.hit-rate-value.rating-good .rate-percent {
  color: var(--color-warning);
}

.rating-badge.rating-good {
  background-color: var(--color-state-warning-bg);
  color: var(--color-state-warning-text);
}

.hit-rate-value.rating-average,
.hit-rate-value.rating-average .rate-number,
.hit-rate-value.rating-average .rate-percent {
  color: var(--color-primary);
}

.rating-badge.rating-average {
  background-color: var(--color-primary);
  color: var(--color-text-inverse);
}

.hit-rate-value.rating-poor,
.hit-rate-value.rating-poor .rate-number,
.hit-rate-value.rating-poor .rate-percent {
  color: var(--color-danger);
}

.rating-badge.rating-poor {
  background-color: var(--color-state-error-bg);
  color: var(--color-state-error-text);
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16px 0;
  border-top: 1px solid var(--color-border-divider);
  border-bottom: 1px solid var(--color-border-divider);
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-icon {
  font-size: 16px;
}

.stat-item.success .stat-icon {
  color: var(--color-success);
}

.stat-item.failure .stat-icon {
  color: var(--color-danger);
}

.stat-item.total .stat-icon {
  color: var(--color-primary);
}

.stat-value {
  font-size: 20px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.stat-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: var(--color-border-divider);
}

/* 趋势显示 */
.trend-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.trend-indicator {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 8px;
  border-radius: 8px;
}

.trend-indicator.up {
  background: var(--color-state-success-bg);
  color: var(--color-success);
}

.trend-indicator.down {
  background: var(--color-state-error-bg);
  color: var(--color-danger);
}

.trend-arrow {
  font-size: 14px;
}

.trend-change {
  font-size: 14px;
  font-weight: 500;
}

.trend-label {
  font-size: 12px;
  color: var(--color-text-muted);
}