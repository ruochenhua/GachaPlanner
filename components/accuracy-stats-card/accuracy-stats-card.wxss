/* 准确度统计卡片组件样式 */

.stats-card {
  background: #FFFFFF;
  border-radius: 12px;
  padding: 20px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 20px;
  font-size: 14px;
  color: #9B9B9B;
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 20px;
}

.empty-text {
  font-size: 14px;
  color: #9B9B9B;
}

/* 统计内容 */
.stats-content {
  display: flex;
  flex-direction: column;
  gap: 20px;
}

/* 命中率展示 */
.hit-rate-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
}

.hit-rate-value {
  display: flex;
  align-items: baseline;
}

.rate-number {
  font-size: 48px;
  font-weight: 600;
}

.rate-percent {
  font-size: 24px;
  font-weight: 400;
  margin-left: 2px;
}

.hit-rate-label {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 14px;
  color: #6B6B6B;
}

.rating-badge {
  padding: 2px 8px;
  border-radius: 12px;
  font-size: 12px;
  color: #FFFFFF;
}

/* 统计行 */
.stats-row {
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding: 16px 0;
  border-top: 1px solid #E5E5E5;
  border-bottom: 1px solid #E5E5E5;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.stat-icon {
  font-size: 16px;
}

.stat-item.success .stat-icon {
  color: #7FB069;
}

.stat-item.failure .stat-icon {
  color: #C47070;
}

.stat-item.total .stat-icon {
  color: #C4A77D;
}

.stat-value {
  font-size: 20px;
  font-weight: 500;
  color: #4A4A4A;
}

.stat-label {
  font-size: 12px;
  color: #9B9B9B;
}

.stat-divider {
  width: 1px;
  height: 40px;
  background: #E5E5E5;
}

/* 趋势显示 */
.trend-section {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
}

.trend-indicator {
  display: flex;
  align-items: center;
  gap: 4px;
  padding: 4px 8px;
  border-radius: 8px;
}

.trend-indicator.up {
  background: rgba(127, 176, 105, 0.15);
  color: #7FB069;
}

.trend-indicator.down {
  background: rgba(196, 112, 112, 0.15);
  color: #C47070;
}

.trend-arrow {
  font-size: 14px;
}

.trend-change {
  font-size: 14px;
  font-weight: 500;
}

.trend-label {
  font-size: 12px;
  color: #9B9B9B;
}