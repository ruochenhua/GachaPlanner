/* 历史数据趋势图表组件样式 */

.trend-chart-container {
  background: var(--color-bg-card);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 16px;
  box-shadow: 0 2px 8px var(--color-shadow);
}

/* 图表标题 */
.chart-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16px;
}

.chart-title {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.chart-range {
  font-size: 12px;
  color: var(--color-text-muted);
}

/* 加载状态 */
.loading-state {
  text-align: center;
  padding: 60px 0;
  font-size: 14px;
  color: var(--color-text-muted);
}

/* 空数据状态 */
.empty-state {
  text-align: center;
  padding: 60px 0;
}

.empty-text {
  font-size: 14px;
  color: var(--color-text-muted);
}

/* Canvas图表 */
.chart-canvas {
  width: 100%;
}

.trend-canvas {
  width: 100%;
  display: block;
}

/* 图例说明 */
.chart-legend {
  display: flex;
  justify-content: center;
  gap: 16px;
  margin-top: 12px;
  padding-top: 12px;
  border-top: 1px solid var(--color-border-divider);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--color-text-secondary);
}

.legend-line {
  width: 16px;
  height: 3px;
  border-radius: 2px;
}

.legend-line.primary {
  background: var(--color-primary);
}

.legend-bar {
  width: 12px;
  height: 12px;
  border-radius: 2px;
}

.legend-bar.success {
  background: var(--color-state-success-bg);
}

.legend-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: var(--color-primary);
}