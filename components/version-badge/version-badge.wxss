/* 版本信息徽章组件样式 */

.version-badge {
  display: inline-flex;
  align-items: center;
}

/* 简单模式 */
.simple-mode {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
}

.version-text {
  color: var(--color-primary);
  font-weight: 500;
}

.separator {
  color: var(--color-text-muted);
}

.date-text {
  color: var(--color-text-secondary);
}

.date-text.expired {
  color: var(--color-warning);
}

/* 详细模式 */
.detail-mode {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 12px 16px;
  background: var(--color-bg-card);
  border-radius: 8px;
  border: 1px solid var(--color-border-divider);
}

.game-name {
  font-size: 16px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.version-info,
.update-info {
  display: flex;
  align-items: center;
  gap: 8px;
}

.version-label,
.update-label {
  font-size: 12px;
  color: var(--color-text-muted);
}

.version-number {
  font-size: 14px;
  color: var(--color-primary);
  font-weight: 500;
}

.update-date {
  font-size: 14px;
  color: var(--color-text-secondary);
}

.update-date.expired {
  color: var(--color-warning);
}

.expired-tag {
  font-size: 10px;
  padding: 2px 6px;
  background: var(--color-state-warning-bg);
  color: var(--color-warning);
  border-radius: 4px;
}