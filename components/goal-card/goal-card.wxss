.goal-card {
  width: 100%;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  position: relative;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.goal-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.game-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.game-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #2C2520;
}

.menu-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-dots {
  font-size: 32rpx;
  color: #7A7168;
  font-weight: bold;
}

.target-summary {
  font-size: 28rpx;
  font-weight: 600;
  color: #2C2520;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.probability-section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.probability-number {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.1;
}

.probability-label {
  font-size: 22rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.detail-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-label {
  font-size: 22rpx;
  color: #7A7168;
}

.detail-value {
  font-size: 26rpx;
  font-weight: 600;
  color: #2C2520;
  min-width: 80rpx;
  text-align: right;
}

.detail-value.danger {
  color: #C47070;
}

.detail-value.success {
  color: #7FB069;
}
