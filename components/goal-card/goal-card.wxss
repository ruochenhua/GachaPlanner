.goal-card {
  width: 100%;
  border-radius: 20rpx;
  padding: 28rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  position: relative;
  box-shadow: 0 2rpx 8rpx var(--color-shadow);
  transition: all 0.2s;
}

.goal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.goal-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.game-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.game-name {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text-primary);
}

.menu-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.menu-dots {
  font-size: 32rpx;
  color: var(--color-text-secondary);
  font-weight: bold;
}

.target-summary {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.probability-section {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.probability-number {
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.1;
}

.probability-label {
  font-size: 22rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.detail-section {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.detail-item {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.detail-label {
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.detail-value {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
  min-width: 80rpx;
  text-align: right;
}

.detail-value.danger {
  color: var(--color-danger);
}

.detail-value.success {
  color: var(--color-success);
}

/* 状态类 - 由 JS 组件动态绑定 */
.goal-card.status-success {
  background-color: var(--color-state-success-bg);
}

.goal-card.status-success .probability-number,
.goal-card.status-success .probability-label {
  color: var(--color-state-success-text);
}

.goal-card.status-warning {
  background-color: var(--color-state-warning-bg);
}

.goal-card.status-warning .probability-number,
.goal-card.status-warning .probability-label {
  color: var(--color-state-warning-text);
}

.goal-card.status-danger {
  background-color: var(--color-state-error-bg);
}

.goal-card.status-danger .probability-number,
.goal-card.status-danger .probability-label {
  color: var(--color-state-error-text);
}
