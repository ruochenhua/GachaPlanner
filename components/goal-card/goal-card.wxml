<view class="goal-card {{statusClass}}" bindtap="onTapTitle">
  <view class="goal-header">
    <view class="goal-header-left">
      <image wx:if="{{gameIcon}}" class="game-icon" src="{{gameIcon}}" mode="aspectFit"></image>
      <text class="game-name">{{gameName}}</text>
    </view>
    <view class="menu-btn" catchtap="onTapMenu">
      <text class="menu-dots">···</text>
    </view>
  </view>

  <!-- 目标摘要 -->
  <view class="target-summary">{{targetSummary}}</view>

  <!-- 概率和抽数信息 -->
  <view class="info-row">
    <view class="probability-section">
      <text class="probability-number">{{probabilityText}}</text>
      <text class="probability-label">达成</text>
    </view>

    <view class="detail-section">
      <view class="detail-item">
        <text class="detail-label">当前</text>
        <text class="detail-value">{{currentPulls}}抽</text>
      </view>
      <view class="detail-item" wx:if="{{neededPulls > 0}}">
        <text class="detail-label">还差</text>
        <text class="detail-value danger">{{neededPulls}}抽</text>
      </view>
      <view class="detail-item" wx:elif="{{neededPulls <= 0}}">
        <text class="detail-label">状态</text>
        <text class="detail-value success">已达成</text>
      </view>
      <view class="detail-item" wx:if="{{daysUntilPool > 0}}">
        <text class="detail-label">开池</text>
        <text class="detail-value">{{daysUntilPool}}天后</text>
      </view>
    </view>
  </view>
</view>
