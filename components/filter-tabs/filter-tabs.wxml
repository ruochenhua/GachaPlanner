<scroll-view class="filter-tabs {{themeClass}}" scroll-x="true" show-scrollbar="false">
  <view class="tabs-inner">
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="tab-item {{activeId === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTap"
    >
      <text class="tab-label">{{item.label}}</text>
    </view>
  </view>
</scroll-view>
