.conflict-alert {
  background: var(--color-state-error-bg);
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  display: flex;
}

.alert-border {
  width: 4rpx;
  background: var(--color-danger);
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
  padding: 24rpx 32rpx;
}

.alert-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.alert-icon {
  font-size: 28rpx;
}

.alert-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-danger);
}

.alert-description {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.conflict-games {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  margin-bottom: 16rpx;
}

.conflict-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.game-name {
  font-size: 26rpx;
  color: var(--color-text-secondary);
}

.game-probability {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-danger);
}

.solution-box {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: var(--color-state-success-bg);
  border-radius: 12rpx;
}

.solution-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.solution-text {
  font-size: 26rpx;
  color: var(--color-text-primary);
  line-height: 1.5;
  flex: 1;
}

.alert-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.btn-help {
  width: 100%;
  height: 72rpx;
  background: var(--color-danger);
  color: var(--color-text-inverse);
  border-radius: 12rpx;
  font-size: 28rpx;
  text-align: center;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.link-dismiss {
  font-size: 26rpx;
  color: var(--color-text-muted);
  text-decoration: underline;
}