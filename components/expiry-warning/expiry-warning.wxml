<view class="expiry-warning {{warningLevel.level}}" wx:if="{{showWarning && !dismissed}}">
  <view class="warning-content">
    <view class="warning-icon">{{warningLevel.icon}}</view>
    <view class="warning-text">
      <text class="warning-title">数据可能过期</text>
      <text class="warning-message">{{message}}</text>
    </view>
  </view>

  <view class="warning-actions">
    <view class="action-btn check-btn" bindtap="onCheckAnnouncement">
      <text>查看官方公告</text>
    </view>
    <view class="action-btn dismiss-btn" bindtap="onDismiss" wx:if="{{dismissible}}">
      <text>关闭提示</text>
    </view>
  </view>
</view>