/* 数据过期警告组件样式 */

.expiry-warning {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 12px 16px;
  background: var(--color-state-warning-bg);
  border-radius: 8px;
  border: 1px solid var(--color-state-warning-bg);
}

.expiry-warning.expired {
  background: var(--color-state-warning-bg);
  border-color: var(--color-state-warning-bg);
}

.expiry-warning.warning {
  background: var(--color-state-warning-bg);
  border-color: var(--color-state-warning-bg);
}

.warning-content {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.warning-icon {
  font-size: 20px;
}

.warning-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.warning-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
}

.warning-message {
  font-size: 12px;
  color: var(--color-text-secondary);
}

.warning-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
}

.check-btn {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.check-btn:active {
  background: var(--color-primary-dark);
}

.dismiss-btn {
  background: transparent;
  border: 1px solid var(--color-border-divider);
  color: var(--color-text-secondary);
}

.dismiss-btn:active {
  background: var(--color-state-warning-bg);
}