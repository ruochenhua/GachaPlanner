/* 数据过期警告组件样式 */

.expiry-warning {
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 12px 16px;
  background: rgba(228, 199, 134, 0.15);
  border-radius: 8px;
  border: 1px solid rgba(228, 199, 134, 0.3);
}

.expiry-warning.expired {
  background: rgba(228, 199, 134, 0.2);
  border-color: rgba(228, 199, 134, 0.5);
}

.expiry-warning.warning {
  background: rgba(228, 199, 134, 0.1);
  border-color: rgba(228, 199, 134, 0.2);
}

.warning-content {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.warning-icon {
  font-size: 20px;
}

.warning-text {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.warning-title {
  font-size: 14px;
  font-weight: 500;
  color: #4A4A4A;
}

.warning-message {
  font-size: 12px;
  color: #6B6B6B;
}

.warning-actions {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
}

.action-btn {
  padding: 6px 12px;
  border-radius: 6px;
  font-size: 12px;
}

.check-btn {
  background: #C4A77D;
  color: #FFFFFF;
}

.check-btn:active {
  background: #A88B5F;
}

.dismiss-btn {
  background: transparent;
  border: 1px solid #D4D4D4;
  color: #6B6B6B;
}

.dismiss-btn:active {
  background: rgba(228, 199, 134, 0.1);
}