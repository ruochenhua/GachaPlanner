/* components/game-card/game-card.wxss */
/* 游戏卡片组件样式 */

.game-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-lg);
  background-color: var(--color-gray-100);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-gray-200);
  transition: all 0.3s ease;
  min-height: 240rpx;
}

.game-card:active {
  transform: scale(0.95);
  background-color: var(--color-gray-200);
}

/* 游戏图标 */
.game-icon-container {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: var(--spacing-sm);
}

.game-icon {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.game-icon-placeholder {
  width: 100%;
  height: 100%;
  background-color: var(--color-primary);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: var(--font-size-2xl);
  font-weight: var(--font-weight-bold);
  color: white;
}

/* 游戏名称 */
.game-name {
  font-size: var(--font-size-base);
  font-weight: var(--font-weight-medium);
  color: var(--color-gray-700);
  margin-bottom: var(--spacing-xs);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
}

/* 资源数量 */
.game-resources {
  display: flex;
  align-items: baseline;
  gap: 4rpx;
  margin-bottom: var(--spacing-xs);
}

.resources-value {
  font-size: var(--font-size-xl);
  font-weight: var(--font-weight-bold);
  color: var(--color-gray-800);
  font-family: 'SF Mono', 'Monaco', monospace;
}

.resources-unit {
  font-size: var(--font-size-sm);
  color: var(--color-gray-600);
}

/* 达成概率 */
.game-probability {
  padding: 4rpx 16rpx;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-sm);
  font-weight: var(--font-weight-semibold);
}

.probability-value {
  font-family: 'SF Mono', 'Monaco', monospace;
}

/* 概率颜色编码 */
.game-probability.success {
  background-color: rgba(127, 176, 105, 0.2);
  color: var(--color-success);
}

.game-probability.warning {
  background-color: rgba(228, 199, 134, 0.2);
  color: var(--color-warning);
}

.game-probability.error {
  background-color: rgba(196, 112, 112, 0.2);
  color: var(--color-danger);
}