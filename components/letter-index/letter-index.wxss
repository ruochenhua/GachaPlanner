.letter-index {
  position: fixed;
  right: 8rpx;
  top: 50%;
  transform: translateY(-50%);
  z-index: var(--z-index-fixed);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background-color: var(--color-bg-card-elevated);
  border-radius: var(--radius-md);
  backdrop-filter: blur(4px);
}

.letter-item {
  width: 32rpx;
  height: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.letter-text {
  font-size: 20rpx;
  color: var(--color-text-secondary);
  font-weight: 500;
}
