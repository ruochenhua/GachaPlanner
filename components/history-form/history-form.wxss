/* 历史记录表单组件样式 */

.history-form-container {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.form-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
}

.form-content {
  position: relative;
  width: 90%;
  max-width: 400px;
  max-height: 80vh;
  background: #FAFAFA;
  border-radius: 12px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}

/* 表单头部 */
.form-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16px;
  border-bottom: 1px solid #E5E5E5;
}

.form-title {
  font-size: 18px;
  font-weight: 500;
  color: #4A4A4A;
}

.close-btn {
  width: 32px;
  height: 32px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.close-btn:active {
  background: #E5E5E5;
}

.close-icon {
  font-size: 24px;
  color: #6B6B6B;
}

/* 表单主体 */
.form-body {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
}

/* 规划关联提示 */
.plan-link-tip {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px;
  margin-bottom: 16px;
  background: #F5F0E6;
  border-radius: 8px;
}

.tip-text {
  font-size: 14px;
  color: #C4A77D;
}

.unlink-btn {
  font-size: 14px;
  color: #C47070;
  text-decoration: underline;
}

/* 表单项 */
.form-item {
  margin-bottom: 16px;
}

.form-label {
  display: block;
  font-size: 14px;
  color: #6B6B6B;
  margin-bottom: 8px;
}

.form-input {
  width: 100%;
  height: 40px;
  padding: 0 12px;
  font-size: 16px;
  color: #4A4A4A;
  background: #FFFFFF;
  border: 1px solid #D4D4D4;
  border-radius: 8px;
  box-sizing: border-box;
}

.form-input:focus {
  border-color: #C4A77D;
}

/* 选择器 */
.picker-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 40px;
  padding: 0 12px;
  background: #FFFFFF;
  border: 1px solid #D4D4D4;
  border-radius: 8px;
}

.picker-arrow {
  font-size: 12px;
  color: #6B6B6B;
}

/* 结果按钮 */
.result-buttons {
  display: flex;
  gap: 12px;
}

.result-btn {
  flex: 1;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 16px;
  transition: all 0.2s;
}

.success-btn {
  background: #FFFFFF;
  border: 1px solid #7FB069;
  color: #7FB069;
}

.success-btn.active {
  background: #7FB069;
  color: #FFFFFF;
}

.failure-btn {
  background: #FFFFFF;
  border: 1px solid #C47070;
  color: #C47070;
}

.failure-btn.active {
  background: #C47070;
  color: #FFFFFF;
}

/* 只读值 */
.readonly-value {
  height: 40px;
  display: flex;
  align-items: center;
  padding: 0 12px;
  background: #F5F5F5;
  border-radius: 8px;
  font-size: 16px;
  color: #6B6B6B;
}

/* 错误提示 */
.error-text {
  display: block;
  font-size: 12px;
  color: #C47070;
  margin-top: 4px;
}

/* 表单底部 */
.form-footer {
  display: flex;
  gap: 12px;
  padding: 16px;
  border-top: 1px solid #E5E5E5;
}

.btn {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  font-size: 16px;
  border: none;
}

.btn-primary {
  background: #C4A77D;
  color: #FFFFFF;
}

.btn-primary:active {
  background: #A88B5F;
}

.btn-secondary {
  background: #FFFFFF;
  border: 1px solid #D4D4D4;
  color: #6B6B6B;
}

.btn-secondary:active {
  background: #F5F5F5;
}