.game-grid {
  padding: 32rpx;
  padding-top: 16rpx;
}

.grid-inner {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.game-card {
  width: calc(50% - 12rpx);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 24rpx;
  background-color: var(--color-bg-card);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border-default);
  transition: all 0.2s ease;
}

.game-card:active {
  opacity: 0.8;
  background-color: var(--color-bg-card-elevated);
}

.icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 16rpx;
}

.game-icon {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
}

.game-icon-fallback {
  width: 100%;
  height: 100%;
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
}

.fallback-letter {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--color-text-inverse);
}

.game-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--color-text-primary);
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 100%;
  margin-bottom: 8rpx;
}

.game-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
}

.meta-hot {
  font-size: 20rpx;
}

.meta-score {
  color: var(--color-warning);
  font-weight: 500;
}

.meta-sep {
  color: var(--color-text-muted);
}

.meta-category {
  color: var(--color-text-muted);
}
