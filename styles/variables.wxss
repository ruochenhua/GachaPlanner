/* 莫兰迪暖色系设计令牌 */

/* 品牌色 */
--primary: #C4A77D;
--primary-light: #D4BC99;
--primary-dark: #A68B5B;

/* 辅助色 */
--secondary: #D4A5A5;
--secondary-light: #E4B5B5;
--secondary-dark: #C49595;

/* 功能色 */
--success: #7FB069;
--success-light: #9FC089;
--success-dark: #6FA059;

--warning: #E4C786;
--warning-light: #F4D796;
--warning-dark: #D4B776;

--error: #C47070;
--error-light: #D48080;
--error-dark: #B46060;

/* 中性色（暖灰色系） */
--gray-50: #FAF8F5;
--gray-100: #F5F3F0;
--gray-200: #EBE8E4;
--gray-300: #D9D5D0;
--gray-400: #A8A29E;
--gray-500: #78716C;
--gray-600: #57534E;
--gray-700: #44403C;
--gray-800: #292524;
--gray-900: #1C1917;

/* 间距 */
--spacing-xs: 4px;
--spacing-sm: 8px;
--spacing-md: 12px;
--spacing-lg: 16px;
--spacing-xl: 24px;
--spacing-2xl: 32px;
--spacing-3xl: 48px;

/* 圆角 */
--radius-sm: 4px;
--radius-md: 8px;
--radius-lg: 12px;

/* 字体大小 */
--font-size-caption: 12px;
--font-size-body-sm: 14px;
--font-size-body: 16px;
--font-size-h4: 18px;
--font-size-h3: 20px;
--font-size-h2: 24px;
--font-size-h1: 32px;

/* 字重 */
--font-weight-regular: 400;
--font-weight-medium: 500;
--font-weight-semibold: 600;
--font-weight-bold: 700;
